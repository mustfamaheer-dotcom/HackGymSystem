@model CreatePlanCommand
@{
    var error = TempData["Error"] as string;
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> New Plan</h4>
                <span class="receipt-badge">Plan</span>
            </div>
            <form asp-action="Create" method="post" class="receipt-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Enter plan name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="e.g. 500" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DurationDays" class="form-label">Duration (Days)</label>
                        <input asp-for="DurationDays" type="number" class="form-control" placeholder="e.g. 30" />
                        <span asp-validation-for="DurationDays" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MaxVisits" class="form-label">Max Visits</label>
                        <input asp-for="MaxVisits" type="number" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="FreezeDays" class="form-label">Freeze Days</label>
                        <input asp-for="FreezeDays" type="number" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Optional description"></textarea>
                    </div>
                </div>
                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
