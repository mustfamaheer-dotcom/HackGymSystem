@{
    var isOwner = User.IsInRole("Owner");
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-grid-1x2-fill"></i> @SharedLocalizer["Hack Gym"]</h4>
        <span class="receipt-badge">@SharedLocalizer["Modules"]</span>
    </div>
    <div class="receipt-body">
        <div class="row g-4">
            <div class="col-md-3 col-6">
                <a asp-controller="DashboardMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-indigo">
                        <i class="bi bi-bar-chart-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Dashboard"]</div>
                        <div class="mod-desc">@SharedLocalizer["Analysis &amp; reports"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="MembersMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-primary">
                        <i class="bi bi-people-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Members"]</div>
                        <div class="mod-desc">@SharedLocalizer["Manage members"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="PlansMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-info">
                        <i class="bi bi-card-list mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Plans"]</div>
                        <div class="mod-desc">@SharedLocalizer["Membership plans"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="MembershipsMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-warning">
                        <i class="bi bi-ticket-perforated-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Memberships"]</div>
                        <div class="mod-desc">@SharedLocalizer["Subscriptions"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="AttendancesMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-danger">
                        <i class="bi bi-check-circle-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Attendance"]</div>
                        <div class="mod-desc">@SharedLocalizer["Check-ins"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="OffersMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-amber">
                        <i class="bi bi-tags-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Offers"]</div>
                        <div class="mod-desc">@SharedLocalizer["Discounts"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="DevicesMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-indigo">
                        <i class="bi bi-display mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Devices"]</div>
                        <div class="mod-desc">@SharedLocalizer["Fingerprint scanners"]</div>
                    </div>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a asp-controller="NotificationsMvc" asp-action="Index" class="text-decoration-none">
                    <div class="mod-card mod-bg-red">
                        <i class="bi bi-bell-fill mod-icon"></i>
                        <div class="mod-title">@SharedLocalizer["Notifications"]</div>
                        <div class="mod-desc">@SharedLocalizer["Messages"]</div>
                    </div>
                </a>
            </div>
            @if (isOwner)
            {
                <div class="col-md-3 col-6">
                    <a asp-controller="UsersMvc" asp-action="Index" class="text-decoration-none">
                        <div class="mod-card mod-bg-gray">
                            <i class="bi bi-shield-lock-fill mod-icon"></i>
                            <div class="mod-title">@SharedLocalizer["Users"]</div>
                            <div class="mod-desc">@SharedLocalizer["Staff accounts"]</div>
                        </div>
                    </a>
                </div>
                <div class="col-md-3 col-6">
                    <a asp-controller="SettingsMvc" asp-action="Index" class="text-decoration-none">
                        <div class="mod-card mod-bg-secondary">
                            <i class="bi bi-gear-fill mod-icon"></i>
                            <div class="mod-title">@SharedLocalizer["Settings"]</div>
                            <div class="mod-desc">@SharedLocalizer["Configuration"]</div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
