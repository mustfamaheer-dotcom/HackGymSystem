@* Access Denied Modal *@
<div class="modal fade" id="accessDeniedModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0" style="justify-content:center;">
                <i class="bi bi-x-circle-fill" style="font-size:3rem;color:#EF4444;"></i>
            </div>
            <div class="modal-body text-center pt-2">
                <h5 class="fw-bold text-danger">@SharedLocalizer["Access Denied"]</h5>
                <p class="text-muted mb-0">@SharedLocalizer["You do not have permission to access this module."]</p>
                <p class="text-muted">@SharedLocalizer["Please contact your administrator if you believe this is a mistake."]</p>
            </div>
            <div class="modal-footer border-0 pt-0" style="justify-content:center;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@SharedLocalizer["Close"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAccessDenied(moduleName) {
            var modal = new bootstrap.Modal(document.getElementById('accessDeniedModal'));
            modal.show();
        }
    </script>
}
