@using Gym.API.Extensions
@{
    var canDashboard = User.HasClaim("permission", "Dashboard.View");
    var canMembers = User.HasClaim("permission", "Members.View");
    var canPlans = User.HasClaim("permission", "Plans.View");
    var canMemberships = User.HasClaim("permission", "Memberships.View");
    var canSubscriptions = User.HasClaim("permission", "Subscriptions.View");
    var canAttendance = User.HasClaim("permission", "Attendance.View");
    var canOffers = User.HasClaim("permission", "Offers.View");
    var canDevices = User.HasClaim("permission", "Devices.View");
    var canWhatsApp = User.HasClaim("permission", "WhatsApp.Send");
    var canNotifications = User.HasClaim("permission", "Notifications.View");
    var canUsers = User.HasClaim("permission", "Users.View");
    var canSettings = User.HasClaim("permission", "Settings.View");
    var canRoles = User.HasClaim("permission", "Roles.View");
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-grid-1x2-fill"></i> @SharedLocalizer["Hack Gym"]</h4>
        <span class="receipt-badge">@SharedLocalizer["Modules"]</span>
    </div>
    <div class="receipt-body">
        <div class="row g-4">
            @if (canDashboard)
            {
                <div class="col-md-3 col-6">
                    <a asp-controller="DashboardMvc" asp-action="Index" class="text-decoration-none">
                        <div class="mod-card mod-bg-indigo">
                            <i class="bi bi-bar-chart-fill mod-icon"></i>
                            <div class="mod-title">@SharedLocalizer["Dashboard"]</div>
                            <div class="mod-desc">@SharedLocalizer["Analysis &amp; reports"]</div>
                        </div>
                    </a>
                </div>
            }
            else
            {
                <div class="col-md-3 col-6">
                    <div class="text-decoration-none" style="cursor:pointer;" onclick="showAccessDenied('@SharedLocalizer["Dashboard"]')">
                        <div class="mod-card mod-bg-indigo" style="opacity:0.5;">
                            <i class="bi bi-bar-chart-fill mod-icon"></i>
                            <div class="mod-title">@SharedLocalizer["Dashboard"]</div>
                            <div class="mod-desc">@SharedLocalizer["Analysis &amp; reports"]</div>
