@model DashboardDto

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-grid-1x2-fill"></i> Hack Gym Dashboard</h4>
        <span class="receipt-badge">Overview</span>
    </div>

    <div class="receipt-body">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="border rounded-3 p-3 text-center bg-primary bg-opacity-10">
                    <i class="bi bi-people-fill fs-2 text-primary"></i>
                    <div class="fs-3 fw-bold mt-2">@Model.TotalMembers</div>
                    <div class="text-muted small">Total Members</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 p-3 text-center bg-success bg-opacity-10">
                    <i class="bi bi-person-check-fill fs-2 text-success"></i>
                    <div class="fs-3 fw-bold mt-2">@Model.ActiveMembers</div>
                    <div class="text-muted small">Active Members</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 p-3 text-center bg-info bg-opacity-10">
                    <i class="bi bi-box-arrow-in-right fs-2 text-info"></i>
                    <div class="fs-3 fw-bold mt-2">@Model.TodayCheckIns</div>
                    <div class="text-muted small">Today's Check-ins</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded-3 p-3 text-center bg-warning bg-opacity-10">
                    <i class="bi bi-exclamation-triangle-fill fs-2 text-warning"></i>
                    <div class="fs-3 fw-bold mt-2">@Model.ExpiringMemberships</div>
                    <div class="text-muted small">Expiring Soon</div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center">
                    <i class="bi bi-cash-stack fs-2 text-success"></i>
                    <div class="fs-4 fw-bold mt-2">@Model.TodayRevenue.ToString("N2") EGP</div>
                    <div class="text-muted small">Today's Revenue</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center">
                    <i class="bi bi-graph-up fs-2 text-primary"></i>
                    <div class="fs-4 fw-bold mt-2">@Model.MonthlyRevenue.ToString("N2") EGP</div>
                    <div class="text-muted small">Monthly Revenue</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded-3 p-3 text-center">
                    <i class="bi bi-credit-card-2-front fs-2 text-danger"></i>
                    <div class="fs-4 fw-bold mt-2">@Model.OverduePayments</div>
                    <div class="text-muted small">Overdue Payments</div>
                </div>
            </div>
        </div>

        @if (Model.RecentActivities.Count > 0)
        {
            <div class="section-divider mt-4"><span>Recent Activity</span></div>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr><th>Type</th><th>Description</th><th>Time</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@activity.Type</span></td>
                                <td>@activity.Description</td>
                                <td class="text-muted small">@activity.Timestamp.ToString("HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.MembershipByPlan.Count > 0)
        {
            <div class="section-divider"><span>Membership Distribution</span></div>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr><th>Plan</th><th>Members</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var stat in Model.MembershipByPlan)
                        {
                            <tr>
                                <td>@stat.PlanName</td>
                                <td>@stat.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
