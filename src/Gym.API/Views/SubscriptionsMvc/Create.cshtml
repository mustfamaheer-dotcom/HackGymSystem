@model CreateSubscriptionCommand
@{
    var error = TempData["Error"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> @SharedLocalizer["New Subscription"]</h4>
                <span class="receipt-badge">@SharedLocalizer["Subscription"]</span>
            </div>
            <form asp-action="Create" method="post" class="receipt-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }

                <div class="row g-3">
                    @* Member - Searchable *@
                    <div class="col-md-12">
                        <label class="form-label">@SharedLocalizer["Member"] <span class="text-danger">*</span></label>
                        <div class="member-search-wrapper">
                            <input type="text" id="memberSearch" class="form-control" placeholder="@SharedLocalizer["Search for a member..."]" autocomplete="off" />
                            <div id="memberResults" class="member-results" style="display:none;"></div>
                            <input type="hidden" asp-for="MemberId" id="memberIdHidden" />
                            <span asp-validation-for="MemberId" class="text-danger small"></span>
                        </div>
                    </div>

                    @* Plan *@
                    <div class="col-md-6">
                        <label asp-for="PlanId" class="form-label">@SharedLocalizer["Plan"]</label>
                        <select asp-for="PlanId" asp-items="ViewBag.Plans" class="form-select" id="planSelect">
                            <option value="">@SharedLocalizer["Select a plan"]</option>
                        </select>
                        <span asp-validation-for="PlanId" class="text-danger small"></span>
                    </div>

                    @* Offer *@
                    <div class="col-md-6">
                        <label asp-for="OfferId" class="form-label">@SharedLocalizer["Offer"]</label>
                        <select asp-for="OfferId" class="form-select" id="offerSelect">
                            <option value="">@SharedLocalizer["No offer"]</option>
                            @foreach (var offer in ViewBag.OfferList as List<dynamic> ?? new())
                            {
                                <option value="@offer.Id">@offer.Display</option>
                            }
                        </select>
                        <span asp-validation-for="OfferId" class="text-danger small"></span>
                    </div>

                    @* Start Date *@
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label">@SharedLocalizer["Start Date"] <span class="text-danger">*</span></label>
                        <input asp-for="StartDate" type="date" class="form-control" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>

                    @* Payment Method *@
                    <div class="col-md-6">
                        <label asp-for="PaymentMethod" class="form-label">@SharedLocalizer["Payment Method"] <span class="text-danger">*</span></label>
                        <select asp-for="PaymentMethod" asp-items="ViewBag.PaymentMethods" class="form-select">
                            <option value="">@SharedLocalizer["Select payment method"]</option>
                        </select>
                        <span asp-validation-for="PaymentMethod" class="text-danger small"></span>
                    </div>

                    @* Amount Paid *@
                    <div class="col-md-4">
                        <label asp-for="AmountPaid" class="form-label">@SharedLocalizer["Amount Paid"] <span class="text-danger">*</span></label>
                        <input asp-for="AmountPaid" type="number" step="0.01" min="0" class="form-control" placeholder="@SharedLocalizer["0.00"]" />
                        <span asp-validation-for="AmountPaid" class="text-danger small"></span>
                    </div>

                    @* Admin Signature *@
                    <div class="col-md-4">
                        <label asp-for="AdminSignature" class="form-label">@SharedLocalizer["Admin Signature"]</label>
                        <input asp-for="AdminSignature" class="form-control" placeholder="@SharedLocalizer["Optional"]" />
                    </div>

                    @* Notes *@
                    <div class="col-md-4">
                        <label asp-for="Notes" class="form-label">@SharedLocalizer["Notes"]</label>
                        <textarea asp-for="Notes" class="form-control" rows="1" placeholder="@SharedLocalizer["Optional"]"></textarea>
                    </div>
                </div>

                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @SharedLocalizer["Create"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.member-search-wrapper { position: relative; }
.member-results {
    position: absolute; top: 100%; left: 0; right: 0; z-index: 1050;
    background: #fff; border: 1px solid #c0c6cc; border-radius: 6px;
    max-height: 220px; overflow-y: auto; box-shadow: 0 8px 24px rgba(0,0,0,0.15);
}
.member-results .member-item {
    padding: 10px 14px; cursor: pointer; display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid #e5e7eb; transition: background 0.15s;
}
.member-results .member-item:last-child { border-bottom: none; }
.member-results .member-item:hover,
.member-results .member-item.active { background: #dbeafe; }
.member-results .member-item .m-name { font-weight: 600; font-size: 0.9rem; color: #1e293b; }
.member-results .member-item .m-phone { font-size: 0.8rem; color: #6b7280; }
.member-results .member-item .m-badge { font-size: 0.7rem; background: #3b82f6; color: #fff; padding: 2px 8px; border-radius: 10px; font-weight: 500; }
.member-no-results { padding: 14px; text-align: center; color: #6b7280; font-size: 0.85rem; }
</style>

<script>
(function() {
    const searchInput = document.getElementById('memberSearch');
    const resultsDiv = document.getElementById('memberResults');
    const hiddenInput = document.getElementById('memberIdHidden');
    const planSelect = document.getElementById('planSelect');
    const offerSelect = document.getElementById('offerSelect');
    let members = [];
    let selectedId = null;
    let activeIndex = -1;

    @{
        var membersJson = System.Text.Json.JsonSerializer.Serialize(
            ((System.Collections.IEnumerable)((SelectList)ViewBag.Members).Items)
                .Cast<dynamic>()
                .Select(m => new {
                    id = ((object)m.Id).ToString(),
                    name = (string)m.FullName
                }).ToList()
        );
        var offersJson = System.Text.Json.JsonSerializer.Serialize(
            ((System.Collections.IEnumerable)ViewBag.OfferList)
                .Cast<dynamic>()
                .Select(o => new {
                    id = ((object)o.Id).ToString(),
                    linkedPackageId = o.LinkedPackageId?.ToString(),
                    offerType = (string)o.OfferType
                }).ToList()
        );
    }
    members = @Html.Raw(membersJson);
    var offers = @Html.Raw(offersJson);

    // --- Offer filtering by plan ---
    function filterOffersByPlan() {
        var planId = planSelect.value;
        var currentOffer = offerSelect.value;

        // Show all offers, highlight incompatible ones using option disabled
        Array.from(offerSelect.options).forEach(function(opt) {
            if (!opt.value) return; // skip "No offer"
            var offerData = offers.find(function(o) { return o.id === opt.value; });
            if (offerData && offerData.linkedPackageId && planId && offerData.linkedPackageId !== planId) {
                opt.disabled = true;
                opt.style.color = '#ccc';
                // If this incompatible offer is currently selected, clear it
                if (offerSelect.value === opt.value) offerSelect.value = '';
            } else {
                opt.disabled = false;
                opt.style.color = '';
            }
        });
    }

    // --- Auto-select plan when an offer with linked package is chosen ---
    function onOfferChange() {
        if (!offerSelect.value) return;
        var offerData = offers.find(function(o) { return o.id === offerSelect.value; });
        if (offerData && offerData.linkedPackageId) {
            // Check if the linked plan exists in the plan dropdown
            var planOpt = Array.from(planSelect.options).find(function(opt) {
                return opt.value === offerData.linkedPackageId;
            });
            if (planOpt) {
                planSelect.value = offerData.linkedPackageId;
            }
        }
        filterOffersByPlan();
    }

    planSelect.addEventListener('change', function() {
        this.classList.remove('is-invalid');
        if (this.value) document.getElementById('offerSelect').classList.remove('is-invalid');
        filterOffersByPlan();
    });

    offerSelect.addEventListener('change', function() {
        this.classList.remove('is-invalid');
        if (this.value) document.getElementById('planSelect').classList.remove('is-invalid');
        onOfferChange();
    });

    // --- Member search ---
    function filterMembers(query) {
        var q = query.toLowerCase().trim();
        if (!q) return members.slice(0, 50);
        return members.filter(function(m) { return m.name.toLowerCase().includes(q); }).slice(0, 50);
    }

    function renderResults(query) {
        var filtered = filterMembers(query);
        activeIndex = -1;
        if (filtered.length === 0 || !query) { resultsDiv.style.display = 'none'; return; }
        resultsDiv.style.display = 'block';
        resultsDiv.innerHTML = filtered.map(function(m, i) {
            return '<div class="member-item" data-index="' + i + '" data-id="' + m.id + '" data-name="' + m.name + '"><div><div class="m-name">' + m.name + '</div></div><div class="m-badge">' + m.id.slice(0,8) + '</div></div>';
        }).join('');

        resultsDiv.querySelectorAll('.member-item').forEach(function(el) {
            el.addEventListener('click', function() { selectMember(this.dataset.id, this.dataset.name); });
            el.addEventListener('mouseenter', function() {
                resultsDiv.querySelectorAll('.member-item').forEach(function(e) { e.classList.remove('active'); });
                this.classList.add('active');
                activeIndex = parseInt(this.dataset.index);
            });
        });
    }

    function selectMember(id, name) {
        selectedId = id;
        hiddenInput.value = id;
        searchInput.value = name;
        resultsDiv.style.display = 'none';
        searchInput.classList.remove('is-invalid');
        searchInput.classList.add('is-valid');
    }

    searchInput.addEventListener('input', function() {
        if (this.value && selectedId && !members.find(function(m) { return m.id === selectedId && m.name === this.value; })) {
            selectedId = null;
            hiddenInput.value = '';
            searchInput.classList.remove('is-valid');
        }
        renderResults(this.value);
    });

    searchInput.addEventListener('focus', function() { if (this.value.length > 0) renderResults(this.value); });
    searchInput.addEventListener('keydown', function(e) {
        var items = resultsDiv.querySelectorAll('.member-item');
        if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, items.length - 1); items.forEach(function(el, i) { el.classList.toggle('active', i === activeIndex); }); if (items[activeIndex]) items[activeIndex].scrollIntoView({ block: 'nearest' }); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, -1); items.forEach(function(el, i) { el.classList.toggle('active', i === activeIndex); }); }
        else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) { e.preventDefault(); items[activeIndex].click(); }
        else if (e.key === 'Escape') { resultsDiv.style.display = 'none'; }
    });
    document.addEventListener('click', function(e) { if (!e.target.closest('.member-search-wrapper')) resultsDiv.style.display = 'none'; });

    // Form validation
    document.querySelector('form').addEventListener('submit', function(e) {
        if (!hiddenInput.value) { e.preventDefault(); searchInput.classList.add('is-invalid'); searchInput.focus(); }
        if (!planSelect.value && !offerSelect.value) { e.preventDefault(); planSelect.classList.add('is-invalid'); offerSelect.classList.add('is-invalid'); }
    });

    // Initial filter
    filterOffersByPlan();
})();
</script>
