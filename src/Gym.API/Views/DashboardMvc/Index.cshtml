@model DetailedDashboardDto
@{
    var now = DateTime.UtcNow;
}

<div class="dash-container" style="max-width:1600px;margin:0 auto;">
    <div class="dash-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:0.75rem;">
        <h2 style="font-family:'Poppins',sans-serif;font-weight:700;color:var(--charcoal);margin:0;font-size:1.35rem;">
            <i style="color:var(--amber);margin-right:0.5rem;" class="bi bi-bar-chart-fill"></i> @SharedLocalizer["Dashboard Analysis"]
        </h2>
        <span class="dash-refresh"><i class="bi bi-arrow-clockwise"></i> @SharedLocalizer["Updated"] @now.ToString("dd MMM yyyy, HH:mm")</span>
    </div>

    @* KPI Cards *@
    <div class="kpi-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem;">
        <div class="kpi-card">
            <div class="kpi-accent" style="background:linear-gradient(135deg,#6366F1,#818CF8)"></div>
            <div class="kpi-top">
                <div class="kpi-value">@Model.Members.TotalMembers</div>
                <div class="kpi-icon icon-bg-indigo"><i class="bi bi-people-fill"></i></div>
            </div>
            <div class="kpi-label">@SharedLocalizer["Total Members"]</div>
            <div class="kpi-sub"><span class="trend-up">+@Model.Members.NewThisMonth</span> @SharedLocalizer["new this month"]</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:linear-gradient(135deg,#10B981,#34D399)"></div>
            <div class="kpi-top">
                <div class="kpi-value">@Model.Memberships.Active</div>
                <div class="kpi-icon icon-bg-green"><i class="bi bi-ticket-perforated-fill"></i></div>
            </div>
            <div class="kpi-label">@SharedLocalizer["Active Memberships"]</div>
            <div class="kpi-sub"><span>@Model.Memberships.ActivePercent%</span> @SharedLocalizer["of total"]</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:linear-gradient(135deg,#F59E0B,#FBBF24)"></div>
            <div class="kpi-top">
                <div class="kpi-value">@Model.Attendance.TodayTotal</div>
                <div class="kpi-icon icon-bg-amber"><i class="bi bi-check-circle-fill"></i></div>
            </div>
            <div class="kpi-label">@SharedLocalizer["Today's Attendance"]</div>
            <div class="kpi-sub"><span class="@(Model.Attendance.TodayTotal > 0 ? "trend-up" : "trend-neutral")">@Model.Attendance.CurrentlyCheckedIn</span> @SharedLocalizer["currently in gym"]</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-accent" style="background:linear-gradient(135deg,#EF4444,#F87171)"></div>
            <div class="kpi-top">
                <div class="kpi-value">@Model.Members.ExpiringThisWeek</div>
                <div class="kpi-icon icon-bg-red"><i class="bi bi-exclamation-triangle-fill"></i></div>
            </div>
            <div class="kpi-label">@SharedLocalizer["Expiring This Week"]</div>
            <div class="kpi-sub">&nbsp;</div>
        </div>
    </div>

    @* Trends Row *@
    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="dash-card">
                <div class="dash-card-header"><i class="bi bi-calendar-check"></i> @SharedLocalizer["Daily Attendance (7 Days)"]</div>
                <div class="dash-card-body">
                    @{
                        var maxAtt = Model.DailyAttendanceTrend.Max(d => d.Count);
                        var attMax = maxAtt > 0 ? maxAtt : 1;
                    }
                    <div class="bar-chart">
                        @foreach (var item in Model.DailyAttendanceTrend)
                        {
                            var heightPct = item.Count * 100.0 / attMax;
                            var color = item.Count == attMax ? "#10B981" : "#3B82F6";
                            <div class="bar-item">
                                <span class="bar-value">@item.Count</span>
                                <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,@color,#60A5FA);"></div>
                                <span class="bar-label">@item.Label</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Analytics Row *@
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="dash-card">
                <div class="dash-card-header"><i class="bi bi-people-fill"></i> @SharedLocalizer["Members Breakdown"]</div>
                <div class="dash-card-body">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.25rem;">
                        <span class="stat-label">@SharedLocalizer["Male"]</span>
                        <span style="font-size:0.82rem;font-weight:600;color:#6366F1;">@Model.Members.MaleCount (@Model.Members.MalePercent%)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
                        <span class="stat-label">@SharedLocalizer["Female"]</span>
                        <span style="font-size:0.82rem;font-weight:600;color:#EC4899;">@Model.Members.FemaleCount (@Model.Members.FemalePercent%)</span>
                    </div>
                    <div class="gender-bar">
                        <div class="male" style="flex:@(Model.Members.MalePercent)"></div>
                        <div class="female" style="flex:@(Model.Members.FemalePercent)"></div>
                    </div>
                    <ul class="insight-list mt-2">
                        <li><span class="insight-dot" style="background:#10B981"></span><span class="insight-text">@SharedLocalizer["Active Members"]</span><span class="insight-value">@Model.Members.ActiveMembers</span></li>
                        <li><span class="insight-dot" style="background:#3B82F6"></span><span class="insight-text">@SharedLocalizer["New This Month"]</span><span class="insight-value trend-up">+@Model.Members.NewThisMonth</span></li>
                        <li><span class="insight-dot" style="background:#F59E0B"></span><span class="insight-text">@SharedLocalizer["Expired Subscriptions"]</span><span class="insight-value" style="color:#EF4444;">@Model.Members.ExpiredSubscriptions</span></li>
                        <li><span class="insight-dot" style="background:#EF4444"></span><span class="insight-text">@SharedLocalizer["Expiring This Week"]</span><span class="insight-value" style="color:#EF4444;">@Model.Members.ExpiringThisWeek</span></li>
                    </ul>
                    @if (Model.MonthlyNewMembersTrend.Any())
                    {
                        var maxNewMembers = Model.MonthlyNewMembersTrend.Max(m => (int)m.Value);
                        var newMemMax = maxNewMembers > 0 ? maxNewMembers : 1;
                        <div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--table-row-border);">
                            <div class="stat-label" style="margin-bottom:0.5rem;">@SharedLocalizer["New Members (6 Months)"]</div>
                            <div style="display:flex;align-items:flex-end;gap:0.35rem;height:40px;">
                                @foreach (var item in Model.MonthlyNewMembersTrend)
                                {
                                    var h = (int)item.Value * 40 / newMemMax;
                                    <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:0.15rem;">
                                        <div style="width:100%;height:@(Math.Max(h,2))px;background:linear-gradient(180deg,#FBBF24,#F59E0B);border-radius:3px 3px 1px 1px;min-height:2px;"></div>
                                        <span class="bar-label">@item.Label</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dash-card">
                <div class="dash-card-header"><i class="bi bi-pie-chart-fill"></i> @SharedLocalizer["Memberships by Plan"]</div>
                <div class="dash-card-body">
                    @if (Model.MembershipByPlan.Count == 0)
                    {
                        <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No active memberships."]</p>
                    }
                    else
                    {
                        var colors = new[] { "#6366F1", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#3B82F6", "#EC4899", "#14B8A6" };
                        var ci = 0;
                        @foreach (var plan in Model.MembershipByPlan)
                        {
                            var c = colors[ci % colors.Length];
                            <div style="margin-bottom:0.85rem;">
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.2rem;">
                                    <span class="insight-text">@plan.PlanName</span>
                                    <span class="stat-value">@plan.Count <span style="font-weight:400;color:var(--text-muted-custom);">(@plan.Percent%)</span></span>
                                </div>
                                <div class="progress-thin"><div class="progress-fill" style="width:@(plan.Percent)%;background:linear-gradient(135deg,@c,transparent);"></div></div>
                            </div>
                            ci++;
                        }
                    }
                    <div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--table-row-border);">
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                            <div class="stat-box stat-box-active">
                                <div class="stat-box-value" style="color:#10B981;">@Model.Memberships.Active</div>
                                <div class="stat-box-label">@SharedLocalizer["Active"]</div>
                            </div>
                            <div class="stat-box stat-box-frozen">
                                <div class="stat-box-value" style="color:#3B82F6;">@Model.Memberships.Frozen</div>
                                <div class="stat-box-label">@SharedLocalizer["Frozen"]</div>
                            </div>
                            <div class="stat-box stat-box-expired">
                                <div class="stat-box-value" style="color:#F59E0B;">@Model.Memberships.Expired</div>
                                <div class="stat-box-label">@SharedLocalizer["Expired"]</div>
                            </div>
                            <div class="stat-box stat-box-cancelled">
                                <div class="stat-box-value" style="color:var(--text-secondary);">@Model.Memberships.Cancelled</div>
                                <div class="stat-box-label">@SharedLocalizer["Cancelled"]</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (User.HasClaim("permission", "Dashboard.Revenue"))
    {
        @* --- Subscription Revenue KPIs --- *@
        <h5 style="font-family:'Poppins',sans-serif;font-weight:600;color:var(--charcoal);margin:1.5rem 0 1rem;display:flex;align-items:center;gap:0.5rem;">
            <i style="color:var(--amber);" class="bi bi-cash-stack"></i> @SharedLocalizer["Subscription Revenue"]
        </h5>

        @* Revenue KPI *@
        <div class="kpi-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem;">
            <div class="kpi-card">
                <div class="kpi-accent" style="background:linear-gradient(135deg,#10B981,#34D399)"></div>
                <div class="kpi-top">
                    <div class="kpi-value" style="font-size:1.1rem;">@Model.Subscriptions.TotalRevenue.ToString("N2")</div>
                    <div class="kpi-icon icon-bg-green"><i class="bi bi-cash"></i></div>
                </div>
                <div class="kpi-label">@SharedLocalizer["Total Revenue"]</div>
                <div class="kpi-sub"><span class="trend-up">@Model.Subscriptions.TodayRevenue.ToString("N2")</span> @SharedLocalizer["today"]</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-accent" style="background:linear-gradient(135deg,#3B82F6,#60A5FA)"></div>
                <div class="kpi-top">
                    <div class="kpi-value" style="font-size:1.1rem;">@Model.Subscriptions.RevenueThisMonth.ToString("N2")</div>
                    <div class="kpi-icon icon-bg-blue"><i class="bi bi-graph-up-arrow"></i></div>
                </div>
                <div class="kpi-label">@SharedLocalizer["Revenue This Month"]</div>
                <div class="kpi-sub"><span class="trend-up">@Model.Subscriptions.RevenueThisWeek.ToString("N2")</span> @SharedLocalizer["this week"]</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-accent" style="background:linear-gradient(135deg,#6366F1,#818CF8)"></div>
                <div class="kpi-top">
                    <div class="kpi-value">@Model.Subscriptions.ActiveSubscriptions</div>
                    <div class="kpi-icon icon-bg-indigo"><i class="bi bi-journal-text"></i></div>
                </div>
                <div class="kpi-label">@SharedLocalizer["Active Subscriptions"]</div>
                <div class="kpi-sub"><span>@Model.Subscriptions.ActivePercent%</span> @SharedLocalizer["of total"]</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-accent" style="background:linear-gradient(135deg,#EF4444,#F87171)"></div>
                <div class="kpi-top">
                    <div class="kpi-value" style="font-size:1.1rem;">@Model.Subscriptions.TotalOutstanding.ToString("N2")</div>
                    <div class="kpi-icon icon-bg-red"><i class="bi bi-exclamation-triangle-fill"></i></div>
                </div>
                <div class="kpi-label">@SharedLocalizer["Outstanding Balance"]</div>
                <div class="kpi-sub"><span>@Model.Subscriptions.ExpiringNext30Days</span> @SharedLocalizer["expiring in 30 days"]</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-accent" style="background:linear-gradient(135deg,#F59E0B,#FBBF24)"></div>
                <div class="kpi-top">
                    <div class="kpi-value">@Model.Subscriptions.AverageSubscriptionValue.ToString("N0")</div>
                    <div class="kpi-icon icon-bg-amber"><i class="bi bi-receipt"></i></div>
                </div>
                <div class="kpi-label">@SharedLocalizer["Avg Subscription Value"]</div>
                <div class="kpi-sub"><span>@Model.Subscriptions.TotalSubscriptions</span> @SharedLocalizer["total subscriptions"]</div>
            </div>
        </div>

        @* Top Revenue Package Highlight *@
        @if (!string.IsNullOrEmpty(Model.TopRevenuePackage.PlanName))
        {
            <div class="dash-card mb-4" style="border-left:4px solid #10B981;">
                <div class="dash-card-body" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
                    <div style="display:flex;align-items:center;gap:1rem;">
                        <div style="width:48px;height:48px;border-radius:12px;background:rgba(16,185,129,0.12);display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-trophy-fill" style="color:#10B981;font-size:1.3rem;"></i>
                        </div>
                        <div>
                            <div style="font-size:0.75rem;color:var(--text-muted-custom);font-weight:500;">@SharedLocalizer["Top Revenue Package"]</div>
                            <div style="font-weight:700;font-size:1.05rem;color:var(--charcoal);">@Model.TopRevenuePackage.PlanName</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:2rem;flex-wrap:wrap;">
                        <div style="text-align:center;">
                            <div style="font-weight:700;font-size:1.1rem;color:#10B981;">@Model.TopRevenuePackage.TotalPaid.ToString("N2")</div>
                            <div style="font-size:0.72rem;color:var(--text-muted-custom);">@SharedLocalizer["Revenue"]</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="font-weight:700;font-size:1.1rem;color:var(--charcoal);">@Model.TopRevenuePackage.SubCount</div>
                            <div style="font-size:0.72rem;color:var(--text-muted-custom);">@SharedLocalizer["Subscriptions"]</div>
                        </div>
                        <div style="text-align:center;">
                            <div style="font-weight:700;font-size:1.1rem;color:#6366F1;">@Model.TopRevenuePackage.PercentOfRevenue%</div>
                            <div style="font-size:0.72rem;color:var(--text-muted-custom);">@SharedLocalizer["of Revenue"]</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* Revenue Trend Charts *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-cash-stack"></i> @SharedLocalizer["Daily Revenue (7 Days)"]</div>
                    <div class="dash-card-body">
                        @{
                            var maxRev = Model.DailySubscriptionRevenue.Max(d => d.Revenue);
                            var revMax = maxRev > 0 ? maxRev : 1;
                        }
                        <div class="bar-chart">
                            @foreach (var item in Model.DailySubscriptionRevenue)
                            {
                                var heightPct = (double)item.Revenue * 100.0 / (double)revMax;
                                <div class="bar-item">
                                    <span class="bar-value" style="font-size:0.7rem;">@item.Revenue.ToString("N0")</span>
                                    <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,#10B981,#34D399);"></div>
                                    <span class="bar-label">@item.Label</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-bar-chart-line"></i> @SharedLocalizer["Monthly Revenue (6 Months)"]</div>
                    <div class="dash-card-body">
                        @{
                            var maxMonthlyRev = Model.MonthlySubscriptionRevenue.Max(m => m.Revenue);
                            var monthlyRevMax = maxMonthlyRev > 0 ? maxMonthlyRev : 1;
                        }
                        <div class="bar-chart">
                            @foreach (var item in Model.MonthlySubscriptionRevenue)
                            {
                                var heightPct = (double)item.Revenue * 100.0 / (double)monthlyRevMax;
                                <div class="bar-item">
                                    <span class="bar-value" style="font-size:0.7rem;">@item.Revenue.ToString("N0")</span>
                                    <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,#6366F1,#818CF8);"></div>
                                    <span class="bar-label">@item.Label</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- AOV Trend + Payment Delay --- *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-graph-up-arrow"></i> @SharedLocalizer["Average Order Value (6 Months)"]</div>
                    <div class="dash-card-body">
                        @if (Model.AovTrend.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No data."]</p>
                        }
                        else
                        {
                            var maxAov = Model.AovTrend.Max(a => (double)a.Aov);
                            var aovMax = maxAov > 0 ? maxAov : 1;
                            <div class="bar-chart">
                                @foreach (var item in Model.AovTrend)
                                {
                                    var heightPct = (double)item.Aov * 100.0 / aovMax;
                                    <div class="bar-item">
                                        <span class="bar-value" style="font-size:0.65rem;">@item.Aov.ToString("N0")</span>
                                        <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,#8B5CF6,#A78BFA);"></div>
                                        <span class="bar-label" style="font-size:0.65rem;">@item.Label</span>
                                    </div>
                                }
                            </div>
                            <div style="display:flex;justify-content:center;gap:1.5rem;margin-top:0.5rem;font-size:0.72rem;color:var(--text-muted-custom);">
                                <span><i class="bi bi-arrow-up" style="color:#8B5CF6;"></i> @SharedLocalizer["Overall AOV"]: @Model.AovTrend.Average(a => (double)a.Aov).ToString("N2")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-clock-history"></i> @SharedLocalizer["Payment Delay Trend (Avg Days)"]</div>
                    <div class="dash-card-body">
                        @if (Model.PaymentDelay.MonthlyTrend.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No payment data."]</p>
                        }
                        else
                        {
                            var maxDelay = Model.PaymentDelay.MonthlyTrend.Max(d => d.AvgDays);
                            var delayMax = maxDelay > 0 ? maxDelay : 1;
                            <div class="bar-chart">
                                @foreach (var item in Model.PaymentDelay.MonthlyTrend)
                                {
                                    var heightPct = item.AvgDays * 100.0 / delayMax;
                                    <div class="bar-item">
                                        <span class="bar-value" style="font-size:0.65rem;">@item.AvgDays.ToString("N1")</span>
                                        <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,#F59E0B,#FBBF24);"></div>
                                        <span class="bar-label" style="font-size:0.65rem;">@item.Label (@item.PaymentCount)</span>
                                    </div>
                                }
                            </div>
                        }
                        <div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--table-row-border);text-align:center;">
                            <span class="stat-label">@SharedLocalizer["Average Payment Delay"]</span>
                            <span style="font-weight:700;font-size:1.1rem;color:#F59E0B;display:block;">@Model.PaymentDelay.AverageDelayDays @SharedLocalizer["days"]</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- Subscription Health + Renewal Rate --- *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-arrow-repeat"></i> @SharedLocalizer["Renewal Rate by Plan"]</div>
                    <div class="dash-card-body">
                        @if (Model.RenewalRateByPlan.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No subscription data."]</p>
                        }
                        else
                        {
                            <div style="margin-bottom:0.75rem;padding-bottom:0.75rem;border-bottom:1px solid var(--table-row-border);text-align:center;">
                                <span class="stat-label" style="display:block;font-size:0.75rem;">@SharedLocalizer["Overall Renewal Rate"]</span>
                                <span style="font-weight:700;font-size:1.25rem;color:#6366F1;">@Model.OverallRenewalRate%</span>
                                <span style="font-size:0.72rem;color:var(--text-muted-custom);">(@Model.RenewalRateByPlan.Sum(r => r.RenewedCount)/@Model.RenewalRateByPlan.Sum(r => r.TotalSubscriptions))</span>
                            </div>
                            var rcolors = new[] { "#6366F1", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6" };
                            var rci = 0;
                            @foreach (var plan in Model.RenewalRateByPlan)
                            {
                                var rc = rcolors[rci % rcolors.Length];
                                <div style="margin-bottom:0.65rem;">
                                    <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.2rem;">
                                        <span class="insight-text">@plan.PlanName</span>
                                        <span>
                                            <span style="font-weight:600;color:@rc;">@plan.RenewalRate%</span>
                                            <span style="font-weight:400;color:var(--text-muted-custom);font-size:0.72rem;">(@plan.RenewedCount/@plan.TotalSubscriptions)</span>
                                        </span>
                                    </div>
                                    <div class="progress-thin"><div class="progress-fill" style="width:@(plan.RenewalRate)%;background:linear-gradient(135deg,@rc,transparent);"></div></div>
                                    <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--text-muted-custom);margin-top:0.1rem;">
                                        <span>@plan.ActiveCount @SharedLocalizer["active"]</span>
                                        <span>@plan.TotalSubscriptions @SharedLocalizer["total"]</span>
                                    </div>
                                </div>
                                rci++;
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-heart-pulse-fill"></i> @SharedLocalizer["Subscription Health"]</div>
                    <div class="dash-card-body">
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="stat-box stat-box-active" style="padding:0.6rem;text-align:center;">
                                    <div class="stat-box-value" style="color:#10B981;font-size:1.1rem;">@Model.Subscriptions.ActiveSubscriptions</div>
                                    <div class="stat-box-label" style="font-size:0.75rem;">@SharedLocalizer["Active"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-box stat-box-frozen" style="padding:0.6rem;text-align:center;">
                                    <div class="stat-box-value" style="color:#3B82F6;font-size:1.1rem;">@Model.Subscriptions.FrozenSubscriptions</div>
                                    <div class="stat-box-label" style="font-size:0.75rem;">@SharedLocalizer["Frozen"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-box stat-box-expired" style="padding:0.6rem;text-align:center;">
                                    <div class="stat-box-value" style="color:#F59E0B;font-size:1.1rem;">@Model.Subscriptions.ExpiredSubscriptions</div>
                                    <div class="stat-box-label" style="font-size:0.75rem;">@SharedLocalizer["Expired"]</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-box" style="padding:0.6rem;text-align:center;background:var(--bg-indigo-soft);">
                                    <div class="stat-box-value" style="color:#6366F1;font-size:1.1rem;">@Model.Subscriptions.RenewedSubscriptions</div>
                                    <div class="stat-box-label" style="font-size:0.75rem;">@SharedLocalizer["Renewed"]</div>
                                </div>
                            </div>
                        </div>
                        <ul class="insight-list">
                            <li><span class="insight-dot" style="background:#10B981"></span><span class="insight-text">@SharedLocalizer["Paid via Offers"]</span><span class="insight-value">@Model.Subscriptions.SubscriptionsWithOffers</span></li>
                            <li><span class="insight-dot" style="background:#3B82F6"></span><span class="insight-text">@SharedLocalizer["Expiring in 7 Days"]</span><span class="insight-value" style="color:#EF4444;">@Model.Subscriptions.ExpiringNext7Days</span></li>
                            <li><span class="insight-dot" style="background:#F59E0B"></span><span class="insight-text">@SharedLocalizer["Expiring in 30 Days"]</span><span class="insight-value">@Model.Subscriptions.ExpiringNext30Days</span></li>
                            <li><span class="insight-dot" style="background:#8B5CF6"></span><span class="insight-text">@SharedLocalizer["Freezes This Month"]</span><span class="insight-value">@Model.Subscriptions.FreezesThisMonth</span></li>
                            <li><span class="insight-dot" style="background:#6366F1"></span><span class="insight-text">@SharedLocalizer["Avg Revenue / Sub"]</span><span class="insight-value">@Model.Subscriptions.AvgRevenuePerSubscription.ToString("N2")</span></li>
                        </ul>
                        @if (Model.Subscriptions.TotalSubscriptions > 0)
                        {
                            var subOccupancy = Model.Subscriptions.ActiveSubscriptions > 0
                                ? Math.Round(Model.Subscriptions.ActiveSubscriptions * 100.0 / Model.Subscriptions.TotalSubscriptions, 1)
                                : 0;
                            <div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--table-row-border);">
                                <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.25rem;">
                                    <span style="font-weight:500;color:var(--text-secondary);">@SharedLocalizer["Active Retention Rate"]</span>
                                    <span style="font-weight:600;color:#10B981;">@subOccupancy%</span>
                                </div>
                                <div class="progress-thin">
                                    <div class="progress-fill" style="width:@(Math.Min(subOccupancy,100))%;background:linear-gradient(135deg,#10B981,#34D399);"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* --- Top Spenders + Overdue Payments --- *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-trophy-fill"></i> @SharedLocalizer["Top Spenders (Top 10%)"]</div>
                    <div class="dash-card-body" style="padding:0.5rem 1.25rem;">
                        @if (Model.TopSpenders.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No payment data."]</p>
                        }
                        else
                        {
                            <div style="max-height:260px;overflow-y:auto;">
                                <table style="width:100%;font-size:0.78rem;border-collapse:collapse;">
                                    <thead>
                                        <tr style="border-bottom:1px solid var(--table-row-border);">
                                            <th style="padding:0.4rem 0.25rem;text-align:left;color:var(--text-secondary);font-weight:500;">#</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:left;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Member"]</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:right;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Paid"]</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:center;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Subs"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.TopSpenders.Count; i++)
                                        {
                                            var s = Model.TopSpenders[i];
                                            <tr style="border-bottom:1px solid var(--table-row-border);">
                                                <td style="padding:0.4rem 0.25rem;color:var(--text-muted-custom);">@(i+1)</td>
                                                <td style="padding:0.4rem 0.25rem;font-weight:500;color:var(--charcoal);">
                                                    @s.MemberName
                                                    <div style="font-size:0.7rem;color:var(--text-muted-custom);">@s.Phone</div>
                                                </td>
                                                <td style="padding:0.4rem 0.25rem;text-align:right;font-weight:600;color:#10B981;">@s.TotalPaid.ToString("N2")</td>
                                                <td style="padding:0.4rem 0.25rem;text-align:center;color:var(--text-secondary);">@s.SubscriptionCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-exclamation-triangle-fill"></i> @SharedLocalizer["Overdue Payments"]</div>
                    <div class="dash-card-body" style="padding:0.5rem 1.25rem;">
                        @if (Model.OverduePayments.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No overdue payments."]</p>
                        }
                        else
                        {
                            <div style="max-height:260px;overflow-y:auto;">
                                <table style="width:100%;font-size:0.78rem;border-collapse:collapse;">
                                    <thead>
                                        <tr style="border-bottom:1px solid var(--table-row-border);">
                                            <th style="padding:0.4rem 0.25rem;text-align:left;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Member"]</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:right;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Due"]</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:right;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Total"]</th>
                                            <th style="padding:0.4rem 0.25rem;text-align:right;color:var(--text-secondary);font-weight:500;">@SharedLocalizer["Expires"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var o in Model.OverduePayments)
                                        {
                                            <tr style="border-bottom:1px solid var(--table-row-border);">
                                                <td style="padding:0.4rem 0.25rem;font-weight:500;color:var(--charcoal);">
                                                    @o.MemberName
                                                    <div style="font-size:0.7rem;color:var(--text-muted-custom);">@o.PlanName</div>
                                                </td>
                                                <td style="padding:0.4rem 0.25rem;text-align:right;font-weight:600;color:#EF4444;">@o.RemainingBalance.ToString("N2")</td>
                                                <td style="padding:0.4rem 0.25rem;text-align:right;color:var(--text-secondary);">@o.TotalValue.ToString("N2")</td>
                                                <td style="padding:0.4rem 0.25rem;text-align:right;font-size:0.72rem;color:var(--text-muted-custom);">@o.ExpirationDate.ToString("dd MMM")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* --- Freeze Impact + Revenue by Plan --- *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-snow2"></i> @SharedLocalizer["Freeze Impact (6 Months)"]</div>
                    <div class="dash-card-body">
                        @if (Model.FreezeImpact.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No freeze data."]</p>
                        }
                        else
                        {
                            var maxFreeze = Model.FreezeImpact.Max(f => f.FreezeCount);
                            var freezeMax = maxFreeze > 0 ? maxFreeze : 1;
                            <div class="bar-chart">
                                @foreach (var item in Model.FreezeImpact)
                                {
                                    var heightPct = item.FreezeCount * 100.0 / freezeMax;
                                    <div class="bar-item">
                                        <span class="bar-value" style="font-size:0.65rem;">@item.FreezeCount</span>
                                        <div class="bar" style="height:@(heightPct)%;background:linear-gradient(180deg,#3B82F6,#60A5FA);"></div>
                                        <span class="bar-label" style="font-size:0.65rem;">@item.Label</span>
                                    </div>
                                }
                            </div>
                            <div style="margin-top:0.5rem;font-size:0.72rem;color:var(--text-muted-custom);text-align:center;">
                                @SharedLocalizer["Revenue vs Freeze Correlation"]: 
                                @{
                                    var withFreeze = Model.FreezeImpact.Where(f => f.FreezeCount > 0).ToList();
                                    var withoutFreeze = Model.FreezeImpact.Where(f => f.FreezeCount == 0).ToList();
                                    var avgWith = withFreeze.Count > 0 ? withFreeze.Average(f => (double)f.Revenue).ToString("N0") : "N/A";
                                    var avgWithout = withoutFreeze.Count > 0 ? withoutFreeze.Average(f => (double)f.Revenue).ToString("N0") : "N/A";
                                }
                                <span style="font-weight:600;color:var(--text-secondary);">@avgWith vs @avgWithout</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-pie-chart-fill"></i> @SharedLocalizer["Revenue by Plan"]</div>
                    <div class="dash-card-body">
                        @if (Model.SubscriptionRevenueByPlan.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No subscription data."]</p>
                        }
                        else
                        {
                            var colors = new[] { "#10B981", "#6366F1", "#F59E0B", "#3B82F6", "#EF4444", "#8B5CF6", "#EC4899", "#14B8A6" };
                            var ci = 0;
                            @foreach (var plan in Model.SubscriptionRevenueByPlan)
                            {
                                var c = colors[ci % colors.Length];
                                <div style="margin-bottom:0.85rem;">
                                    <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.2rem;">
                                        <span class="insight-text">@plan.PlanName</span>
                                        <span>
                                            <span class="stat-value">@plan.TotalPaid.ToString("N2")</span>
                                            <span style="font-weight:400;color:var(--text-muted-custom);font-size:0.75rem;">(@plan.Percent%)</span>
                                        </span>
                                    </div>
                                    <div class="progress-thin"><div class="progress-fill" style="width:@(plan.Percent)%;background:linear-gradient(135deg,@c,transparent);"></div></div>
                                    <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:var(--text-muted-custom);margin-top:0.15rem;">
                                        <span>@plan.Count @SharedLocalizer["subs"]</span>
                                        <span>@SharedLocalizer["Due"]: @plan.TotalOutstanding.ToString("N2")</span>
                                    </div>
                                </div>
                                ci++;
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @* --- Recent Subscription Activity --- *@
        <div class="row g-3 mb-4">
            <div class="col-md-12">
                <div class="dash-card">
                    <div class="dash-card-header"><i class="bi bi-journal-text"></i> @SharedLocalizer["Recent Subscriptions"]</div>
                    <div class="dash-card-body" style="padding:0.75rem 1.25rem;">
                        @if (Model.RecentSubscriptionActivity.Count == 0)
                        {
                            <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No subscriptions yet."]</p>
                        }
                        else
                        {
                            <ul class="activity-feed" style="max-height:220px;overflow-y:auto;">
                                @foreach (var activity in Model.RecentSubscriptionActivity)
                                {
                                    var isOffer = activity.Type == "subscription_offer";
                                    <li>
                                        <div class="activity-icon" style="background:@(isOffer ? "rgba(245,158,11,0.15)" : "rgba(16,185,129,0.15)");">
                                            <i class="bi @(isOffer ? "bi-tag-fill" : "bi-journal-plus")" style="color:@(isOffer ? "#F59E0B" : "#10B981");"></i>
                                        </div>
                                        <div class="activity-content">
                                            <div class="act-desc">@activity.Description</div>
                                            <div class="act-time">@activity.Timestamp.ToString("dd MMM yyyy")</div>
                                        </div>
                                        <span class="act-time" style="white-space:nowrap;">@activity.Timestamp.ToString("HH:mm")</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* Recent Activity + Attendance Summary *@
    <div class="row g-3">
        <div class="col-md-7">
            <div class="dash-card">
                <div class="dash-card-header"><i class="bi bi-clock-history"></i> @SharedLocalizer["Recent Activity"]</div>
                <div class="dash-card-body" style="padding:0.75rem 1.25rem;">
                    @if (Model.RecentActivities.Count == 0)
                    {
                        <p style="color:var(--text-muted-custom);font-size:0.85rem;text-align:center;padding:1rem 0;">@SharedLocalizer["No recent activity."]</p>
                    }
                    else
                    {
                        <ul class="activity-feed" style="max-height:260px;overflow-y:auto;">
                            @foreach (var activity in Model.RecentActivities)
                            {
                                var isCheckIn = activity.Description.Contains("Checked in");
                                <li>
                                    <div class="activity-icon @(isCheckIn ? "" : "checkout")">
                                        <i class="bi @(isCheckIn ? "bi-box-arrow-in-right" : "bi-box-arrow-right")"></i>
                                    </div>
                                    <div class="activity-content">
                                        <div class="act-desc">@activity.Description</div>
                                        <div class="act-time">@activity.Timestamp.ToString("dd MMM yyyy")</div>
                                    </div>
                                    <span class="act-time" style="white-space:nowrap;">@activity.Timestamp.ToString("HH:mm")</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="dash-card">
                <div class="dash-card-header"><i class="bi bi-bar-chart-fill"></i> @SharedLocalizer["Attendance Summary"]</div>
                <div class="dash-card-body">
                    <ul class="insight-list">
                        <li><span class="insight-dot" style="background:#3B82F6"></span><span class="insight-text">@SharedLocalizer["Today"]</span><span class="insight-value">@Model.Attendance.TodayTotal</span></li>
                        <li><span class="insight-dot" style="background:#6366F1"></span><span class="insight-text">@SharedLocalizer["This Week"]</span><span class="insight-value">@Model.Attendance.ThisWeekTotal</span></li>
                        <li><span class="insight-dot" style="background:#10B981"></span><span class="insight-text">@SharedLocalizer["This Month"]</span><span class="insight-value">@Model.Attendance.ThisMonthTotal</span></li>
                        <li><span class="insight-dot" style="background:#F59E0B"></span><span class="insight-text">@SharedLocalizer["Avg Daily This Month"]</span><span class="insight-value">@Model.Attendance.AvgDailyThisMonth</span></li>
                        <li><span class="insight-dot" style="background:#8B5CF6"></span><span class="insight-text">@SharedLocalizer["Currently in Gym"]</span><span class="insight-value" style="color:#10B981;">@Model.Attendance.CurrentlyCheckedIn</span></li>
                    </ul>
                    @if (Model.Memberships.Active > 0)
                    {
                        var occupancyRate = Math.Round(Model.Attendance.CurrentlyCheckedIn * 100.0 / Model.Memberships.Active, 1);
                        <div style="margin-top:1rem;padding-top:0.75rem;border-top:1px solid var(--table-row-border);">
                            <div style="display:flex;justify-content:space-between;font-size:0.82rem;margin-bottom:0.25rem;">
                                <span style="font-weight:500;color:var(--text-secondary);">@SharedLocalizer["Current Occupancy"]</span>
                                <span style="font-weight:600;color:#10B981;">@occupancyRate%</span>
                            </div>
                            <div class="progress-thin">
                                <div class="progress-fill" style="width:@(Math.Min(occupancyRate,100))%;background:linear-gradient(135deg,#10B981,#34D399);"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
