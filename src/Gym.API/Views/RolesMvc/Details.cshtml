@model RoleDetailDto
@{
    var groups = ViewBag.PermissionGroups as List<PermissionGroupDto> ?? new();
    var hasPermIds = Model.PermissionIds.ToHashSet();
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-shield-lock-fill"></i> @SharedLocalizer["Role Details"]</h4>
        <span class="receipt-badge">@Model.Name</span>
    </div>
    <div class="receipt-body">
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="detail-label">@SharedLocalizer["Role Name"]</div>
                <div class="detail-value">@Model.Name</div>
            </div>
            <div class="col-md-4">
                <div class="detail-label">@SharedLocalizer["Status"]</div>
                <div class="detail-value">
                    @if (Model.IsActive)
                    {
                        <span class="badge-status badge-active">@SharedLocalizer["Active"]</span>
                    }
                    else
                    {
                        <span class="badge-status badge-expired">@SharedLocalizer["Inactive"]</span>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="detail-label">@SharedLocalizer["System Role"]</div>
                <div class="detail-value">@(Model.IsSystem ? SharedLocalizer["Yes"] : SharedLocalizer["No"])</div>
            </div>
            <div class="col-12">
                <div class="detail-label">@SharedLocalizer["Description"]</div>
                <div class="detail-value">@Model.Description</div>
            </div>
            <div class="col-12">
                <div class="detail-label">@SharedLocalizer["Created"]</div>
                <div class="detail-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
            </div>
        </div>

        <div class="section-divider mb-4">
            <span>@SharedLocalizer["Assigned Permissions"]</span>
        </div>

        <div class="accordion" id="permAccordion">
            @for (var g = 0; g < groups.Count; g++)
            {
                var group = groups[g];
                var hasAny = group.Permissions.Any(p => hasPermIds.Contains(p.Id));
                if (!hasAny) continue;
                var isFirst = g == 0;
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#permGroup@(g)">
                            <strong>@group.Module</strong>
                            <span class="badge bg-success ms-2 rounded-pill">@group.Permissions.Count(p => hasPermIds.Contains(p.Id))</span>
                        </button>
                    </h2>
                    <div id="permGroup@(g)" class="accordion-collapse collapse @(isFirst ? "show" : "")" data-bs-parent="#permAccordion">
                        <div class="accordion-body">
                            <div class="row">
                                @foreach (var perm in group.Permissions.Where(p => hasPermIds.Contains(p.Id)))
                                {
                                    <div class="col-md-4 col-6 mb-2">
                                        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-circle-fill me-1 small"></i> @perm.Name
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="receipt-footer">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> @SharedLocalizer["Back"]
            </a>
        </div>
    </div>
</div>
