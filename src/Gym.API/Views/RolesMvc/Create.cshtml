@using Gym.API.Extensions
@model CreateRoleDto
@{
    var groups = ViewBag.PermissionGroups as List<PermissionGroupDto> ?? new();
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-plus-lg"></i> @SharedLocalizer["New Role"]</h4>
    </div>
    <div class="receipt-body">
        <form asp-action="Create" method="post">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">@SharedLocalizer["Role Name"] *</label>
                    <input asp-for="Name" class="form-control" required maxlength="100" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">@SharedLocalizer["Status"]</label>
                    <select asp-for="IsActive" class="form-select">
                        <option value="true">@SharedLocalizer["Active"]</option>
                        <option value="false">@SharedLocalizer["Inactive"]</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">@SharedLocalizer["Description"]</label>
                    <textarea asp-for="Description" class="form-control" rows="2" maxlength="500"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            <div class="section-divider mb-4">
                <span>@SharedLocalizer["Permissions"]</span>
            </div>

            <div class="accordion" id="permAccordion">
                @for (var g = 0; g < groups.Count; g++)
                {
                    var group = groups[g];
                    var isFirst = g == 0;
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(isFirst ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#permGroup@(g)">
                                <strong>@group.Module</strong>
                                <span class="badge bg-secondary ms-2 rounded-pill">@group.Permissions.Count</span>
                            </button>
                        </h2>
                        <div id="permGroup@(g)" class="accordion-collapse collapse @(isFirst ? "show" : "")" data-bs-parent="#permAccordion">
                            <div class="accordion-body">
                                <div class="row">
                                    @foreach (var perm in group.Permissions)
                                    {
                                        <div class="col-md-4 col-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input perm-checkbox" type="checkbox"
                                                       name="PermissionIds" value="@perm.Id" id="perm_@perm.Id" />
                                                <label class="form-check-label small" for="perm_@perm.Id">
                                                    @perm.Name
                                                    @if (!string.IsNullOrEmpty(perm.Description))
                                                    {
                                                        <br /><span class="text-muted" style="font-size:0.7rem;">@perm.Description</span>
                                                    }
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="receipt-footer">
                <a asp-action="Index" class="btn btn-outline-secondary">@SharedLocalizer["Cancel"]</a>
                <button type="submit" class="btn btn-primary">@SharedLocalizer["Create Role"]</button>
            </div>
        </form>
    </div>
</div>

