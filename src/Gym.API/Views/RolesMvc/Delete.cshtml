@model RoleDetailDto

<div class="receipt-card">
    <div class="receipt-header" style="background:linear-gradient(135deg, rgba(239,68,68,0.12), rgba(254,202,202,0.08));">
        <h4 style="color:#991B1B;"><i class="bi bi-exclamation-triangle-fill"></i> @SharedLocalizer["Delete Role"]</h4>
    </div>
    <div class="receipt-body">
        <div class="delete-banner p-4 mb-4 text-center">
            <i class="bi bi-shield-exclamation" style="font-size:3rem;color:#EF4444;"></i>
            <h5 class="mt-3 fw-bold text-danger">@SharedLocalizer["Are you sure?"]</h5>
            <p class="text-muted mb-0">
                @SharedLocalizer["You are about to delete the role"] "<strong>@Model.Name</strong>".
                @SharedLocalizer["This action cannot be undone."]
            </p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="detail-label">@SharedLocalizer["Role Name"]</div>
                <div class="detail-value">@Model.Name</div>
            </div>
            <div class="col-md-6">
                <div class="detail-label">@SharedLocalizer["Status"]</div>
                <div class="detail-value">
                    @if (Model.IsActive)
                    {
                        <span class="badge-status badge-active">@SharedLocalizer["Active"]</span>
                    }
                    else
                    {
                        <span class="badge-status badge-expired">@SharedLocalizer["Inactive"]</span>
                    }
                </div>
            </div>
            <div class="col-12">
                <div class="detail-label">@SharedLocalizer["Description"]</div>
                <div class="detail-value">@Model.Description</div>
            </div>
        </div>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="receipt-footer">
                <a asp-action="Index" class="btn btn-outline-secondary">@SharedLocalizer["Cancel"]</a>
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> @SharedLocalizer["Delete Role"]
                </button>
            </div>
        </form>
    </div>
</div>
