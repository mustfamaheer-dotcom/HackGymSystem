@{
    ViewData["Title"] = SharedLocalizer["Access Denied"];
}

<div class="receipt-card" style="max-width:500px;margin:3rem auto;">
    <div class="receipt-header" style="background:linear-gradient(135deg,rgba(239,68,68,0.12),rgba(254,202,202,0.08));">
        <h4 style="color:#991B1B;"><i class="bi bi-shield-exclamation"></i> @SharedLocalizer["Access Denied"]</h4>
    </div>
    <div class="receipt-body text-center py-5">
        <i class="bi bi-x-circle-fill" style="font-size:4rem;color:#EF4444;"></i>
        <h4 class="mt-3 fw-bold text-danger">@SharedLocalizer["Access Denied"]</h4>
        <p class="text-muted mt-2 mb-4">
            @SharedLocalizer["You do not have permission to access this module."]
            @SharedLocalizer["Please contact your administrator if you believe this is a mistake."]
        </p>
        <a asp-controller="HomeMvc" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house-fill"></i> @SharedLocalizer["Go Home"]
        </a>
    </div>
</div>
