@model PaginatedResult<DeviceDto>
@{
    var searchTerm = ViewBag.SearchTerm as string;
}
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-hdd-stack"></i> @SharedLocalizer["Devices"]</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> @SharedLocalizer["New Device"]</a>
    </div>
    <div class="p-3 border-bottom bg-light">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="@SharedLocalizer["Search by name..."]" value="@searchTerm" />
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="col-md-2">
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    <option value="10" selected="@(Model?.PageSize == 10 ? "selected" : null)">@SharedLocalizer["10 per page"]</option>
                    <option value="20" selected="@(Model?.PageSize == 20 ? "selected" : null)">@SharedLocalizer["20 per page"]</option>
                    <option value="50" selected="@(Model?.PageSize == 50 ? "selected" : null)">@SharedLocalizer["50 per page"]</option>
                </select>
            </div>
        </form>
    </div>
    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success m-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger m-3">@TempData["Error"]</div>
    }
    @if (Model is null || Model.Items.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-hdd-stack" style="font-size: 3rem;"></i>
            <p class="mt-2">@SharedLocalizer["No devices found."]</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>@SharedLocalizer["Name"]</th>
                        <th>@SharedLocalizer["IP Address"]</th>
                        <th>@SharedLocalizer["Port"]</th>
                        <th>@SharedLocalizer["Status"]</th>
                        <th>@SharedLocalizer["Active"]</th>
                        <th>@SharedLocalizer["Last Connected"]</th>
                        <th>@SharedLocalizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@device.Name</td>
                            <td>@device.IPAddress</td>
                            <td>@device.Port</td>
                            <td>
                                <span class="badge-status @(device.Status == DeviceStatus.Online ? "badge-active" : device.Status == DeviceStatus.Error ? "badge-expired" : "badge-warning")">@SharedLocalizer[device.Status.ToString()]</span>
                            </td>
                            <td>
                                <span class="badge-status @(device.IsActive ? "badge-active" : "badge-expired")">@(device.IsActive ? SharedLocalizer["Yes"] : SharedLocalizer["No"])</span>
                            </td>
                            <td>@(device.LastConnectedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@device.Id" class="btn btn-outline-primary" title="@SharedLocalizer["View"]"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@device.Id" class="btn btn-outline-secondary" title="@SharedLocalizer["Edit"]"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@device.Id" class="btn btn-outline-danger" title="@SharedLocalizer["Delete"]"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">@SharedLocalizer["Showing"] @Model.Items.Count @SharedLocalizer["of"] @Model.TotalCount @SharedLocalizer["devices"]</small>
            <nav>
                <ul class="pagination pagination-sm">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">@SharedLocalizer["Previous"]</a></li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">@i</a></li>
                    }
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">@SharedLocalizer["Next"]</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
