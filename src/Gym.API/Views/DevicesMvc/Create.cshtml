@model CreateDeviceCommand
@{
    var error = TempData["Error"] as string;
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> @SharedLocalizer["New Device"]</h4>
                <span class="receipt-badge">@SharedLocalizer["Device"]</span>
            </div>
            <form asp-action="Create" method="post" class="receipt-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="@SharedLocalizer["Enter device name"]" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="IPAddress" class="form-label">@SharedLocalizer["IP Address"]</label>
                        <input asp-for="IPAddress" class="form-control" placeholder="@SharedLocalizer["e.g. 192.168.1.100"]" />
                        <span asp-validation-for="IPAddress" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Port" class="form-label">@SharedLocalizer["Port"]</label>
                        <input asp-for="Port" type="number" class="form-control" placeholder="@SharedLocalizer["e.g. 8080"]" />
                        <span asp-validation-for="Port" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Model" class="form-label">@SharedLocalizer["Model"]</label>
                        <input asp-for="Model" class="form-control" placeholder="@SharedLocalizer["Optional"]" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SerialNumber" class="form-label">@SharedLocalizer["Serial Number"]</label>
                        <input asp-for="SerialNumber" class="form-control" placeholder="@SharedLocalizer["Optional"]" />
                    </div>
                </div>
                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @SharedLocalizer["Create"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
