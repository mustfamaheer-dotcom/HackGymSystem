@model DeviceDto
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-hdd-stack"></i> @Model.Name</h4>
        <span class="receipt-badge">@SharedLocalizer[Model.Status.ToString()]</span>
    </div>
    <div class="receipt-body">
        <div class="section-title"><i class="bi bi-info-circle"></i> @SharedLocalizer["Device Information"]</div>
        <table class="table table-borderless table-sm">
            <tr><td class="detail-label">@SharedLocalizer["Name"]</td><td class="detail-value">@Model.Name</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["IP Address"]</td><td class="detail-value">@Model.IPAddress</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Port"]</td><td class="detail-value">@Model.Port</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Model"]</td><td class="detail-value">@(Model.Model ?? "-")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Serial Number"]</td><td class="detail-value">@(Model.SerialNumber ?? "-")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Firmware Version"]</td><td class="detail-value">@(Model.FirmwareVersion ?? "-")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Status"]</td><td class="detail-value">@SharedLocalizer[Model.Status.ToString()]</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Is Active"]</td><td class="detail-value">@(Model.IsActive ? SharedLocalizer["Yes"] : SharedLocalizer["No"])</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Last Connected"]</td><td class="detail-value">@(Model.LastConnectedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td></tr>
        </table>
        <div class="section-divider"><span>@SharedLocalizer["Timestamps"]</span></div>
        <div class="row g-3">
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center">
                    <div class="detail-label">@SharedLocalizer["Created"]</div>
                    <div class="fw-semibold mt-1">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center">
                    <div class="detail-label">@SharedLocalizer["Updated"]</div>
                    <div class="fw-semibold mt-1">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="receipt-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> @SharedLocalizer["Edit"]</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger"><i class="bi bi-trash"></i> @SharedLocalizer["Delete"]</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> @SharedLocalizer["Back to List"]</a>
    </div>
</div>
