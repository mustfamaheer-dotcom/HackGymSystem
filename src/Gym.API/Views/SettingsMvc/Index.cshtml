@model List<SettingDto>
@{
    var groups = ViewBag.Groups as List<string>;
}
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-gear-fill"></i> Settings</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> New Setting</a>
    </div>
    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success m-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger m-3">@TempData["Error"]</div>
    }
    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-gear" style="font-size: 3rem;"></i>
            <p class="mt-2">No settings found.</p>
        </div>
    }
    else
    {
        <div class="receipt-body">
            @foreach (var group in groups!)
            {
                var groupKey = group ?? "General";
                <div class="section-title mt-3 mb-2">
                    <i class="bi bi-folder"></i> @groupKey
                </div>
                <div class="table-responsive mb-4">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Value</th>
                                <th>Description</th>
                                <th>Encrypted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Where(s => s.Group == group))
                            {
                                <tr>
                                    <td class="fw-semibold">@s.Key</td>
                                    <td class="text-muted" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@(s.IsEncrypted ? "********" : s.Value)</td>
                                    <td>@(s.Description ?? "-")</td>
                                    <td>
                                        @if (s.IsEncrypted)
                                        {
                                            <span class="badge-status badge-expired"><i class="bi bi-lock-fill"></i> Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status badge-active"><i class="bi bi-unlock-fill"></i> No</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>
