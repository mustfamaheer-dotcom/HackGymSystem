@model List<SettingDto>
@{
    var groups = ViewBag.Groups as List<string>;
    var groupIcons = new Dictionary<string, string>
    {
        ["General"] = "bi-gear",
        ["Device"] = "bi-router",
        ["Backup"] = "bi-cloud-arrow-up",
    };
    var groupColors = new Dictionary<string, string>
    {
        ["General"] = "#6366F1",
        ["Device"] = "#F59E0B",
        ["Backup"] = "#3B82F6",
    };
}
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-gear-fill"></i> @SharedLocalizer["Settings"]</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> @SharedLocalizer["New Setting"]</a>
    </div>
    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-gear" style="font-size: 3rem;"></i>
            <p class="mt-2">@SharedLocalizer["No settings found."]</p>
        </div>
    }
    else
    {
        <div class="receipt-body">
            @foreach (var group in groups!)
            {
                var groupKey = group ?? SharedLocalizer["General"];
                var icon = groupIcons.GetValueOrDefault(groupKey, "bi-folder");
                var color = groupColors.GetValueOrDefault(groupKey, "#6366F1");
                var items = Model.Where(s => s.Group == group).ToList();
                <div class="card border-0 shadow-sm mb-4" style="border-radius:16px;overflow:hidden;">
                    <div class="card-header d-flex align-items-center gap-2 border-0 px-4 py-3" style="background:@color;color:#fff;">
                        <i class="bi @icon fs-5"></i>
                        <h5 class="mb-0 fs-6 fw-semibold">@groupKey</h5>
                        <span class="ms-auto badge bg-white text-dark rounded-pill px-3 py-1" style="font-size:0.75rem;font-weight:400;">@items.Count @SharedLocalizer["setting(s)"]</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:200px;">@SharedLocalizer["Key"]</th>
                                        <th>@SharedLocalizer["Value"]</th>
                                        <th style="width:280px;">@SharedLocalizer["Description"]</th>
                                        <th style="width:95px;">@SharedLocalizer["Encrypted"]</th>
                                        <th style="width:70px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in items)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@s.Key</td>
                                            <td>
                                                <code class="px-2 py-1 rounded" style="font-size:0.8rem;background:var(--light-gray);color:var(--charcoal);display:inline-block;max-width:100%;overflow:hidden;text-overflow:ellipsis;">
                                                    @(s.IsEncrypted ? "********" : s.Value)
                                                </code>
                                            </td>
                                            <td class="text-muted" style="font-size:0.85rem;">@(s.Description ?? "-")</td>
                                            <td>
                                                @if (s.IsEncrypted)
                                                {
                                                    <span class="badge-status badge-expired"><i class="bi bi-lock-fill"></i> @SharedLocalizer["Yes"]</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-status badge-active"><i class="bi bi-unlock-fill"></i> @SharedLocalizer["No"]</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm" title="@SharedLocalizer["Edit"]" style="border-radius:8px;background:var(--light-gray);color:var(--text-secondary);border:none;padding:0.3rem 0.6rem;">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
