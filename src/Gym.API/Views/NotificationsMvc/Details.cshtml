@model NotificationDto
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-bell-fill"></i> @Model.Subject</h4>
        <span class="receipt-badge">@SharedLocalizer[Model.Status.ToString()]</span>
    </div>
    <div class="receipt-body">
        <div class="section-title"><i class="bi bi-info-circle"></i> @SharedLocalizer["Notification Information"]</div>
        <table class="table table-borderless table-sm">
            <tr><td class="detail-label">@SharedLocalizer["Subject"]</td><td class="detail-value">@Model.Subject</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Message"]</td><td class="detail-value">@Model.Message</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Type"]</td><td class="detail-value"><span class="badge-status badge-active">@Model.Type</span></td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Channel"]</td><td class="detail-value">@Model.Channel</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Status"]</td><td class="detail-value">
                <span class="badge-status @(Model.Status == NotificationStatus.Sent ? "badge-active" : Model.Status == NotificationStatus.Failed ? "badge-expired" : "badge-frozen")">@SharedLocalizer[Model.Status.ToString()]</span>
            </td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Member"]</td><td class="detail-value">@(Model.MemberName ?? SharedLocalizer["N/A"])</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Pending"]</td><td class="detail-value">@(Model.IsPending ? SharedLocalizer["Yes"] : SharedLocalizer["No"])</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Retry Count"]</td><td class="detail-value">@Model.RetryCount</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Last Error"]</td><td class="detail-value">@(Model.LastError ?? "-")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Scheduled Date"]</td><td class="detail-value">@(Model.ScheduledDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Sent Date"]</td><td class="detail-value">@(Model.SentDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td></tr>
        </table>
        <div class="section-divider"><span>@SharedLocalizer["Timestamps"]</span></div>
        <div class="row g-3">
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center">
                    <div class="detail-label">@SharedLocalizer["Created"]</div>
                    <div class="fw-semibold mt-1">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center">
                    <div class="detail-label">@SharedLocalizer["Updated"]</div>
                    <div class="fw-semibold mt-1">@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="receipt-footer">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> @SharedLocalizer["Back to List"]</a>
    </div>
</div>
