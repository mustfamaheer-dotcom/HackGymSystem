@{
    var error = ViewBag.Error as string;
    Layout = null;
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@SharedLocalizer["Login - Hack Gym"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --gold: #FFD54A;
            --amber: #F4B400;
            --charcoal: #333333;
            --soft-gray: #6B7280;
            --off-white: #F8F9FA;
            --light-gray: #F3F4F6;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.04);
            --shadow-md: 0 8px 30px rgba(0,0,0,0.08);
            --shadow-lg: 0 20px 60px rgba(0,0,0,0.12);
            --shadow-glow: 0 8px 32px rgba(244,180,0,0.3);
        }
        html, body { height: 100%; }
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--off-white);
            color: var(--charcoal);
            overflow: hidden;
        }

        .split-layout {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* ── Left Panel ── */
        .left-panel {
            flex: 0 0 45%;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 2.5rem;
            background: linear-gradient(160deg, #0f0c29 0%, #1a1a2e 40%, #16213e 70%, #0f3460 100%);
            overflow: hidden;
        }
        .left-panel::before {
            content: '';
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse at 15% 85%, rgba(255,213,74,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 85% 15%, rgba(244,180,0,0.06) 0%, transparent 50%);
            z-index: 1;
        }
        .left-panel .bg-pattern {
            position: absolute; inset: 0;
            background-image:
                radial-gradient(circle at 20% 30%, rgba(255,255,255,0.02) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(255,213,74,0.03) 0%, transparent 50%);
            background-size: 80px 80px;
            z-index: 1;
        }
        .left-panel .glow-orb {
            position: absolute;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,213,74,0.08) 0%, transparent 60%);
            top: -200px; right: -150px;
            pointer-events: none;
            z-index: 1;
            animation: orbFloat 8s ease-in-out infinite alternate;
        }
        .left-panel .glow-orb-2 {
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 60%);
            bottom: -180px; left: -120px;
            pointer-events: none;
            z-index: 1;
            animation: orbFloat 10s ease-in-out infinite alternate-reverse;
        }
        @@keyframes orbFloat {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(30px, -30px) scale(1.1); }
        }
        .left-content {
            position: relative;
            z-index: 2;
            max-width: 520px;
            text-align: center;
        }
        .left-content .logo-area {
            display: flex;
            justify-content: center;
            margin-bottom: 2.5rem;
        }
        .left-content .logo-area img {
            height: 130px;
            width: auto;
            border-radius: 20px;
            filter: drop-shadow(0 8px 30px rgba(255,213,74,0.3));
            transition: transform 0.4s ease;
        }
        .left-content .logo-area img:hover {
            transform: scale(1.05);
        }
        .left-content .headline {
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            font-size: 2.8rem;
            line-height: 1.15;
            color: #fff;
            margin-bottom: 0.75rem;
            letter-spacing: -0.5px;
        }
        .left-content .headline .gold-text {
            background: linear-gradient(135deg, var(--gold), var(--amber));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .left-content .subtitle {
            font-size: 0.95rem;
            line-height: 1.7;
            color: rgba(255,255,255,0.55);
            margin-bottom: 2rem;
            max-width: 440px;
            margin-left: auto;
            margin-right: auto;
        }
        .feature-cards {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            max-width: 400px;
            margin: 0 auto;
        }
        .feature-card {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            padding: 0.85rem 1.1rem;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 14px;
            backdrop-filter: blur(8px);
            transition: all 0.3s ease;
            cursor: default;
        }
        .feature-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,213,74,0.25);
            transform: translateX(6px);
        }
        .feature-card .fc-icon {
            width: 36px; height: 36px;
            border: 1.5px solid rgba(255,213,74,0.5);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: var(--gold);
            font-size: 1rem;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .feature-card:hover .fc-icon {
            border-color: var(--gold);
            background: rgba(255,213,74,0.12);
            box-shadow: 0 0 20px rgba(255,213,74,0.15);
        }
        .feature-card .fc-text { font-size: 0.88rem; color: rgba(255,255,255,0.75); font-weight: 500; }
        .feature-card .fc-text strong { color: #fff; font-weight: 600; }

        /* ── Right Panel ── */
        .right-panel {
            flex: 0 0 55%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: linear-gradient(135deg, #F8F9FA 0%, #F3F4F6 100%);
            position: relative;
        }
        .right-panel::before {
            content: '';
            position: absolute; top: -40%; right: -20%;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(255,213,74,0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .right-panel::after {
            content: '';
            position: absolute; bottom: -30%; left: -15%;
            width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(99,102,241,0.05) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .auth-card {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 440px;
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.8);
            border-radius: 28px;
            box-shadow: 0 25px 80px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
            padding: 2.75rem 2.5rem;
            animation: cardFadeIn 0.6s ease;
        }
        .auth-card::before {
            content: '';
            position: absolute;
            top: -1px; left: -1px; right: -1px;
            height: 4px;
            background: linear-gradient(90deg, var(--gold), var(--amber), #6366F1, var(--gold));
            background-size: 300% 100%;
            border-radius: 28px 28px 0 0;
            animation: shimmerBorder 4s linear infinite;
        }
        @@keyframes shimmerBorder {
            0% { background-position: 0% 0; }
            100% { background-position: 300% 0; }
        }
        @@keyframes cardFadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .auth-header {
            margin-bottom: 2rem;
        }
        .auth-header h1 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.75rem;
            color: var(--charcoal);
            margin-bottom: 0.35rem;
            letter-spacing: -0.3px;
        }
        .auth-header p {
            font-size: 0.92rem;
            color: var(--soft-gray);
        }

        .form-group {
            margin-bottom: 1.25rem;
            position: relative;
        }
        .form-group .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }
        .form-group .input-icon {
            position: absolute;
            left: 1rem;
            color: #9CA3AF;
            font-size: 1rem;
            z-index: 1;
            pointer-events: none;
            transition: color 0.2s ease;
        }
        .form-group .input-wrapper:focus-within .input-icon {
            color: var(--amber);
        }
        .form-group .form-input {
            width: 100%;
            padding: 0.85rem 1rem 0.85rem 2.8rem;
            font-size: 0.92rem;
            font-family: inherit;
            color: var(--charcoal);
            background: var(--off-white);
            border: 1.5px solid #E5E7EB;
            border-radius: 14px;
            outline: none;
            transition: all 0.25s ease;
        }
        .form-group .form-input:focus {
            border-color: var(--amber);
            box-shadow: 0 0 0 4px rgba(244,180,0,0.1);
            background: #fff;
        }
        .form-group .form-input::placeholder {
            color: #9CA3AF;
            font-weight: 400;
        }
        .form-group .form-input.error {
            border-color: #EF4444;
            box-shadow: 0 0 0 4px rgba(239,68,68,0.1);
        }

        .form-group .toggle-pw {
            position: absolute;
            right: 0.75rem;
            background: none;
            border: none;
            color: #9CA3AF;
            cursor: pointer;
            padding: 0.5rem;
            font-size: 1.05rem;
            border-radius: 8px;
            transition: all 0.2s ease;
        }
        .form-group .toggle-pw:hover { color: var(--soft-gray); background: rgba(0,0,0,0.03); }

        .form-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }
        .remember-me {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: var(--soft-gray);
            cursor: pointer;
        }
        .remember-me input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: var(--amber);
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-primary {
            width: 100%;
            padding: 0.9rem 1.5rem;
            font-size: 0.95rem;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            color: var(--charcoal);
            background: linear-gradient(135deg, var(--gold), var(--amber));
            border: none;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(244,180,0,0.35);
        }
        .btn-primary:active {
            transform: translateY(0);
        }
        .btn-primary .ripple {
            position: absolute;
            border-radius: 50%;
            background: rgba(51,51,51,0.15);
            transform: scale(0);
            animation: rippleAnim 0.6s ease;
            pointer-events: none;
        }
        @@keyframes rippleAnim {
            to { transform: scale(4); opacity: 0; }
        }
        .btn-primary .btn-spinner {
            width: 18px; height: 18px;
            border: 2px solid rgba(51,51,51,0.2);
            border-top-color: var(--charcoal);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            display: none;
        }
        .btn-primary.loading .btn-spinner { display: block; }
        .btn-primary.loading .btn-text { display: none; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.25rem 0;
        }
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #E5E7EB;
        }
        .divider span {
            font-size: 0.8rem;
            color: #9CA3AF;
            font-weight: 500;
        }

        .btn-secondary {
            width: 100%;
            padding: 0.85rem 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
            font-family: inherit;
            color: var(--soft-gray);
            background: transparent;
            border: 1.5px solid #E5E7EB;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .btn-secondary:hover {
            border-color: #D1D5DB;
            background: rgba(0,0,0,0.02);
            color: var(--charcoal);
        }

        .auth-footer {
            margin-top: 1.5rem;
            text-align: center;
        }
        .auth-footer .security-msg {
            font-size: 0.75rem;
            color: #9CA3AF;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
        }
        .auth-footer .security-msg i { font-size: 0.7rem; }

        .error-toast {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.75rem 1rem;
            background: #FEF2F2;
            border: 1px solid #FEE2E2;
            border-radius: 12px;
            margin-bottom: 1.25rem;
            font-size: 0.85rem;
            color: #991B1B;
            animation: slideDown 0.3s ease;
        }
        .error-toast i { color: #EF4444; font-size: 1rem; }
        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── Responsive ── */
        @@media (max-width: 1024px) {
            .left-panel { flex: 0 0 40%; padding: 2rem 1.5rem; }
            .right-panel { flex: 0 0 60%; }
            .left-content .headline { font-size: 2rem; }
        }
        @@media (max-width: 820px) {
            .left-panel { flex: 0 0 100%; height: auto; padding: 2rem 1.5rem; justify-content: flex-start; }
            .right-panel { flex: 0 0 100%; padding: 1.5rem; overflow-y: auto; }
            .split-layout { flex-direction: column; overflow-y: auto; }
            body { overflow: auto; }
            .left-content { max-width: 100%; }
            .left-content .headline { font-size: 1.8rem; }
            .auth-card { padding: 2rem 1.5rem; max-width: 100%; }
            .feature-cards { flex-direction: row; flex-wrap: wrap; }
            .feature-card { flex: 1; min-width: 160px; }
            .left-panel::before { display: none; }
            .left-content .logo-area { margin-bottom: 1.5rem; }
            .left-content .subtitle { margin-bottom: 1.25rem; font-size: 0.85rem; }
        }
        @@media (max-width: 480px) {
            .left-panel { padding: 1.5rem 1rem; }
            .right-panel { padding: 1rem; }
            .auth-card { padding: 1.5rem 1.25rem; border-radius: 20px; }
            .auth-header h1 { font-size: 1.4rem; }
            .left-content .headline { font-size: 1.5rem; }
            .feature-card { min-width: 100%; }
            .form-row { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        }

        /* ── RTL Support ── */
        [dir="rtl"] body { font-family: 'Tajawal', 'Inter', system-ui, sans-serif; }
        [dir="rtl"] .auth-card { direction: rtl; text-align: right; }
        [dir="rtl"] .auth-card input { text-align: right; }
        [dir="rtl"] .form-check { padding-right: 1.5em; padding-left: 0; }
        [dir="rtl"] .form-check .form-check-input { float: right; margin-left: 0; margin-right: -1.5em; }
        [dir="rtl"] .left-content { direction: rtl; }
        [dir="rtl"] .left-content h1 { font-family: 'Tajawal', 'Poppins', sans-serif; }
        [dir="rtl"] .feature-card { direction: rtl; }
        [dir="rtl"] .login-security { direction: rtl; }

        /* ── Reduced Motion ── */
        @@media (prefers-reduced-motion: reduce) {
            .auth-card, .error-toast, .feature-card,
            .btn-primary, .btn-secondary { animation: none; transition: none; }
        }
    </style>
</head>
<body>
    <div class="split-layout">
        @* ── Left Panel ── *@
        <div class="left-panel">
            <div class="bg-pattern"></div>
            <div class="left-content">
                <div class="logo-area">
                    <img src="/logo.png" alt="@SharedLocalizer["Hack Gym"]" />
                </div>
                <h1 class="headline">
                    @SharedLocalizer["STRONGER"]<br>
                    <span class="gold-text">@SharedLocalizer["EVERY DAY"]</span>
                </h1>
                <p class="subtitle">
                    @SharedLocalizer["The all-in-one platform to manage members, workouts, subscriptions, trainers, and grow your fitness business."]
                </p>
                <div class="feature-cards">
                    <div class="feature-card">
                        <div class="fc-icon"><i class="bi bi-people"></i></div>
                        <span class="fc-text"><strong>@SharedLocalizer["Manage Members"]</strong> @SharedLocalizer["&mdash; Track profiles, attendance &amp; payments"]</span>
                    </div>
                    <div class="feature-card">
                        <div class="fc-icon"><i class="bi bi-graph-up-arrow"></i></div>
                        <span class="fc-text"><strong>@SharedLocalizer["Track Workouts"]</strong> @SharedLocalizer["&mdash; Monitor performance &amp; progress"]</span>
                    </div>
                    <div class="feature-card">
                        <div class="fc-icon"><i class="bi bi-bar-chart-fill"></i></div>
                        <span class="fc-text"><strong>@SharedLocalizer["Grow Business"]</strong> @SharedLocalizer["&mdash; Analytics, reports &amp; insights"]</span>
                    </div>
                </div>
            </div>
        </div>

        @* ── Right Panel ── *@
        <div class="right-panel">
            <div class="auth-card">
                <div class="auth-header">
                    <h1>@SharedLocalizer["Welcome Back!"]</h1>
                    <p>@SharedLocalizer["Sign in to your account to continue"]</p>
                </div>

                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="error-toast" role="alert">
                        <i class="bi bi-exclamation-circle-fill"></i>
                        <span>@error</span>
                    </div>
                }

                <form method="post" action="/Account/Login" id="loginForm" novalidate>
                    <div class="form-group">
                        <label for="username" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">@SharedLocalizer["Username"]</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person input-icon"></i>
                            <input type="text" id="username" name="username" class="form-input" placeholder="@SharedLocalizer["Username"]" required autocomplete="username" autofocus />
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">@SharedLocalizer["Password"]</label>
                        <div class="input-wrapper">
                            <i class="bi bi-lock input-icon"></i>
                            <input type="password" id="password" name="password" class="form-input" placeholder="@SharedLocalizer["Password"]" required autocomplete="current-password" />
                            <button type="button" class="toggle-pw" onclick="togglePassword()" aria-label="@SharedLocalizer["Show password"]" tabindex="-1">
                                <i class="bi bi-eye-slash" id="pwIcon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-row">
                        <label class="remember-me">
                            <input type="checkbox" name="remember" value="true" checked />
                            @SharedLocalizer["Remember me"]
                        </label>
                    </div>

                    <button type="submit" class="btn-primary" id="loginBtn" onclick="handleSubmit(this)">
                        <span class="btn-spinner"></span>
                        <span class="btn-text"><i class="bi bi-box-arrow-in-right"></i> @SharedLocalizer["Sign In"]</span>
                    </button>
                </form>

                <div class="divider"><span>@SharedLocalizer["OR"]</span></div>

                <button type="button" class="btn-secondary" aria-label="@SharedLocalizer["Secure login"]">
                    <i class="bi bi-shield-check"></i> @SharedLocalizer["Secure Login"]
                </button>

                <div class="auth-footer">
                    <span class="security-msg">
                        <i class="bi bi-lock-fill"></i>
                        @SharedLocalizer["Your data is 100% secure and encrypted."]
                    </span>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            var pw = document.getElementById('password');
            var icon = document.getElementById('pwIcon');
            if (pw.type === 'password') {
                pw.type = 'text';
                icon.className = 'bi bi-eye';
            } else {
                pw.type = 'password';
                icon.className = 'bi bi-eye-slash';
            }
        }

        function handleSubmit(btn) {
            btn.classList.add('loading');
            setTimeout(function() { btn.classList.remove('loading'); }, 3000);
        }

        // Ripple effect on primary button
        document.querySelector('.btn-primary').addEventListener('click', function(e) {
            var rect = this.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            var ripple = document.createElement('span');
            ripple.className = 'ripple';
            ripple.style.left = x + 'px';
            ripple.style.top = y + 'px';
            ripple.style.width = ripple.style.height = '20px';
            this.appendChild(ripple);
            setTimeout(function() { ripple.remove(); }, 600);
        });

        // Keyboard: Enter on username moves to password
        document.getElementById('username').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('password').focus();
            }
        });
    </script>
</body>
</html>
