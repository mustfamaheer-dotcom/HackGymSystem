@model PaginatedResult<MemberDto>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var sortBy = ViewBag.SortBy as string;
    var sortDesc = (bool)(ViewBag.SortDescending ?? false);
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-people-fill"></i> Members</h4>
        <button type="button" onclick="window.location.href='/Members/Create'" class="inline-flex items-center justify-center font-medium rounded-xl transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-indigo-600 text-white hover:bg-indigo-700 focus:ring-indigo-500 shadow-md hover:shadow-lg px-4 py-2 text-sm">Add Member</button>
    </div>
    <div class="p-3 border-bottom bg-light">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by name, receipt, phone, or National ID..." value="@searchTerm" />
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="col-md-2">
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    @{
                        var ps1 = Model?.PageSize == 10 ? "selected" : "";
                        var ps2 = Model?.PageSize == 20 ? "selected" : "";
                        var ps3 = Model?.PageSize == 50 ? "selected" : "";
                    }
                    <option value="10" selected="@ps1">10 per page</option>
                    <option value="20" selected="@ps2">20 per page</option>
                    <option value="50" selected="@ps3">50 per page</option>
                </select>
            </div>
            <div class="col-md-6 text-end">
                <a asp-action="Import" class="btn btn-outline-primary btn-sm rounded-pill"><i class="bi bi-upload"></i> Import Excel</a>
                <a asp-action="Search" class="btn btn-outline-gold btn-sm rounded-pill"><i class="bi bi-search"></i> Advanced Search</a>
            </div>
        </form>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success m-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger m-3">@TempData["Error"]</div>
    }

    @if (Model is null || Model.Items.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-people" style="font-size: 3rem;"></i>
            <p class="mt-2">No members found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Receipt</th>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Plan</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Paid</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Items)
                    {
                        var isExpired = member.SubscriptionEndDate <= DateTime.UtcNow;
                        var status = isExpired ? "Expired" : (member.IsDeleted ? "Deleted" : "Active");
                        var badgeClass = isExpired ? "badge-expired" : (member.IsDeleted ? "badge-expired" : "badge-active");
                        <tr>
                            <td><span class="fw-semibold">@member.ReceiptNumber</span></td>
                            <td>@member.FullName</td>
                            <td>@member.PhoneNumber</td>
                            <td>@(member.PackageName ?? "-")</td>
                            <td>@member.SubscriptionEndDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge-status @badgeClass">@status</span></td>
                            <td>@member.PaidAmount.ToString("N2") EGP</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@member.Id" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Items.Count of @Model.TotalCount members</small>
            <nav>
                <ul class="pagination pagination-sm">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">Previous</a>
                        </li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">@i</a>
                        </li>
                    }
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
