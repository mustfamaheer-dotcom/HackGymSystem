@model MemberImportResult
@{
    ViewData["Title"] = "Import Results";
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-clipboard-data"></i> Import Results</h4>
        <span class="receipt-badge">@Model.TotalRows rows</span>
    </div>

    <div class="receipt-body">
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center" style="background: #D1FAE5;">
                    <div class="detail-label text-success">Imported Successfully</div>
                    <div class="fs-3 fw-bold text-success">@Model.SuccessCount</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="border rounded-3 p-3 text-center" style="background: #FEE2E2;">
                    <div class="detail-label text-danger">Failed</div>
                    <div class="fs-3 fw-bold text-danger">@Model.FailedCount</div>
                </div>
            </div>
        </div>

        @if (Model.Imported.Count > 0)
        {
            <div class="section-title text-success"><i class="bi bi-check-circle"></i> Imported Records (@Model.Imported.Count)</div>
            <div class="table-responsive mb-4">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Row</th>
                            <th>Receipt Number</th>
                            <th>Full Name</th>
                            <th>Phone</th>
                            <th>National ID</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Imported)
                        {
                            <tr>
                                <td>@row.RowNumber</td>
                                <td><span class="fw-semibold">@row.ReceiptNumber</span></td>
                                <td>@row.FullName</td>
                                <td>@row.PhoneNumber</td>
                                <td>@(row.NationalId ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Failed.Count > 0)
        {
            <div class="section-title text-danger"><i class="bi bi-x-circle"></i> Failed Records (@Model.Failed.Count)</div>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Row</th>
                            <th>Full Name</th>
                            <th>Phone</th>
                            <th>National ID</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Failed)
                        {
                            <tr>
                                <td>@row.RowNumber</td>
                                <td>@(row.FullName ?? "-")</td>
                                <td>@(row.PhoneNumber ?? "-")</td>
                                <td>@(row.NationalId ?? "-")</td>
                                <td><span class="text-danger">@row.FailureReason</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="receipt-footer">
        <a asp-action="Import" class="btn btn-outline-primary"><i class="bi bi-upload"></i> Import Another File</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to Members</a>
    </div>
</div>
