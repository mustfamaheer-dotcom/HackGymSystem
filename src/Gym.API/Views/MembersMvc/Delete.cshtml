@using Gym.Application.Members.DTOs
@model MemberDto
@{
    var error = TempData["Error"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="receipt-card text-center">
            <div class="receipt-header" style="background: linear-gradient(135deg, #FEE2E2, #FECACA);">
                <h4 class="text-danger"><i class="bi bi-exclamation-triangle"></i> @SharedLocalizer["Delete Member"]</h4>
                <span class="receipt-badge">@SharedLocalizer["Confirm"]</span>
            </div>

            <div class="receipt-body">
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }

                <div class="mb-4">
                    <i class="bi bi-person text-danger" style="font-size: 4rem;"></i>
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted mb-1">@SharedLocalizer["Member #{0} · Receipt {1}", Model.Code, Model.ReceiptNumber]</p>
                <p class="text-muted mb-1">@Model.PhoneNumber</p>

                <div class="alert alert-warning mt-4">
                    <i class="bi bi-info-circle"></i>
                    @SharedLocalizer["This will soft-delete the member. The member can be restored later."]
                </div>

                <table class="table table-borderless table-sm text-start">
                    <tr><td class="detail-label">@SharedLocalizer["Plan"]</td><td class="detail-value">@(Model.PackageName ?? "-")</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["End Date"]</td><td class="detail-value">@Model.SubscriptionEndDate.ToString("dd/MM/yyyy")</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Remaining"]</td><td class="detail-value">@SharedLocalizer["{0} EGP", Model.RemainingAmount.ToString("N2")]</td></tr>
                </table>

                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> @SharedLocalizer["Confirm Delete"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
