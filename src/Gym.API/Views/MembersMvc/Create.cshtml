@model CreateMemberDto

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-plus-circle"></i> @SharedLocalizer["Add Member"]</h4>
        <span class="receipt-badge">@SharedLocalizer["Receipt"]</span>
    </div>

    <form asp-action="Create" method="post" class="receipt-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="section-title"><i class="bi bi-person-badge"></i> @SharedLocalizer["Basic Information"]</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="@SharedLocalizer["Enter full name"]" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label">@SharedLocalizer["Phone"]</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="@SharedLocalizer["11 digits"]" maxlength="11" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="@SharedLocalizer["email@example.com"]" />
            </div>
            <div class="col-md-3">
                <label asp-for="DateOfBirth" class="form-label">@SharedLocalizer["Date of Birth"]</label>
                <input asp-for="DateOfBirth" class="form-control" type="date" />
            </div>
            <div class="col-md-3">
                <label asp-for="Gender" class="form-label"></label>
                <select asp-for="Gender" class="form-select">
                    <option value="">@SharedLocalizer["Select gender"]</option>
                    <option value="Male">@SharedLocalizer["Male"]</option>
                    <option value="Female">@SharedLocalizer["Female"]</option>
                </select>
            </div>
            <div class="col-md-12">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" placeholder="@SharedLocalizer["Address"]" />
            </div>
            <div class="col-md-12">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="@SharedLocalizer["Additional notes"]"></textarea>
            </div>
            <div class="col-md-4">
                <label asp-for="Nationality" class="form-label"></label>
                <select asp-for="Nationality" class="form-select">
                    <option value="">@SharedLocalizer["Select nationality"]</option>
                    <option value="Egyptian">@SharedLocalizer["Egyptian"]</option>
                    <option value="Saudi">@SharedLocalizer["Saudi"]</option>
                    <option value="Emirati">@SharedLocalizer["Emirati"]</option>
                    <option value="Kuwaiti">@SharedLocalizer["Kuwaiti"]</option>
                    <option value="Qatari">@SharedLocalizer["Qatari"]</option>
                    <option value="Bahraini">@SharedLocalizer["Bahraini"]</option>
                    <option value="Omani">@SharedLocalizer["Omani"]</option>
                    <option value="Jordanian">@SharedLocalizer["Jordanian"]</option>
                    <option value="Lebanese">@SharedLocalizer["Lebanese"]</option>
                    <option value="Syrian">@SharedLocalizer["Syrian"]</option>
                    <option value="Palestinian">@SharedLocalizer["Palestinian"]</option>
                    <option value="Iraqi">@SharedLocalizer["Iraqi"]</option>
                    <option value="Yemeni">@SharedLocalizer["Yemeni"]</option>
                    <option value="Libyan">@SharedLocalizer["Libyan"]</option>
                    <option value="Tunisian">@SharedLocalizer["Tunisian"]</option>
                    <option value="Algerian">@SharedLocalizer["Algerian"]</option>
                    <option value="Moroccan">@SharedLocalizer["Moroccan"]</option>
                    <option value="Sudanese">@SharedLocalizer["Sudanese"]</option>
                    <option value="Other">@SharedLocalizer["Other"]</option>
                </select>
                <span asp-validation-for="Nationality" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="NationalId" class="form-label">@SharedLocalizer["National ID"]</label>
                <input asp-for="NationalId" class="form-control" placeholder="@SharedLocalizer["14-digit ID"]" maxlength="14" />
                <span asp-validation-for="NationalId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="ReferralSource" class="form-label">@SharedLocalizer["Referral Source"]</label>
                <select asp-for="ReferralSource" class="form-select">
                    <option value="">@SharedLocalizer["Select referral source"]</option>
                    <option value="Social Media">@SharedLocalizer["Social Media"]</option>
                    <option value="Friend">@SharedLocalizer["Friend"]</option>
                    <option value="Walk-in">@SharedLocalizer["Walk-in"]</option>
                    <option value="Advertisement">@SharedLocalizer["Advertisement"]</option>
                    <option value="Other">@SharedLocalizer["Other"]</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="Company" class="form-label"></label>
                <input asp-for="Company" class="form-control" placeholder="@SharedLocalizer["Company"]" />
            </div>
        </div>

        <div class="section-divider"><span>@SharedLocalizer["Subscription"]</span></div>
        <div class="section-title"><i class="bi bi-calendar-check"></i> @SharedLocalizer["Subscription Information"]</div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="PackageId" class="form-label">@SharedLocalizer["Membership Plan"]</label>
                <select asp-for="PackageId" class="form-select">
                    <option value="">@SharedLocalizer["-- Select Plan --"]</option>
                    @if (ViewBag.Plans is not null)
                    {
                        var plans = ViewBag.Plans as IEnumerable<Gym.Domain.Entities.MembershipPlan>;
                        if (plans is not null)
                        {
                            foreach (var plan in plans)
                            {
                                <option value="@plan.Id">@SharedLocalizer["{0} ({1} EGP)", plan.Name, plan.Price.ToString("N2")]</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="SubscriptionPrice" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="SubscriptionPrice" class="form-control" type="number" step="0.01" min="0" id="SubscriptionPrice" />
                    <span class="input-group-text">@SharedLocalizer["EGP"]</span>
                </div>
            </div>
            <div class="col-md-4">
                <label asp-for="SubscriptionDurationMonths" class="form-label">@SharedLocalizer["Duration (months)"]</label>
                <input asp-for="SubscriptionDurationMonths" class="form-control" type="number" min="1" value="1" />
            </div>
            <div class="col-md-4">
                <label asp-for="SubscriptionStartDate" class="form-label">@SharedLocalizer["Start Date"]</label>
                <input asp-for="SubscriptionStartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-4">
                <label asp-for="FreeMonths" class="form-label">@SharedLocalizer["Free Months"]</label>
                <input asp-for="FreeMonths" class="form-control" type="number" min="0" value="0" />
            </div>
            <div class="col-md-4">
                <label asp-for="FreezeDays" class="form-label">@SharedLocalizer["Freeze Days"]</label>
                <input asp-for="FreezeDays" class="form-control" type="number" min="0" value="0" />
            </div>
        </div>

        <div class="section-divider"><span>@SharedLocalizer["Payment"]</span></div>
        <div class="section-title"><i class="bi bi-credit-card"></i> @SharedLocalizer["Payment"]</div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="PaidAmount" class="form-label">@SharedLocalizer["Amount Paid"]</label>
                <div class="input-group">
                    <input asp-for="PaidAmount" class="form-control" type="number" step="0.01" min="0" id="PaidAmount" />
                    <span class="input-group-text">@SharedLocalizer["EGP"]</span>
                </div>
            </div>
            <div class="col-md-4">
                <label asp-for="PaymentMethod" class="form-label"></label>
                <select asp-for="PaymentMethod" class="form-select">
                    <option value="Cash">@SharedLocalizer["Cash"]</option>
                    <option value="Visa">@SharedLocalizer["Visa"]</option>
                    <option value="Instapay">@SharedLocalizer["Instapay"]</option>
                    <option value="Wallet">@SharedLocalizer["Wallet"]</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">@SharedLocalizer["Remaining"]</label>
                <div class="input-group">
                    <input class="form-control" id="remainingAmount" readonly value="0" />
                    <span class="input-group-text">@SharedLocalizer["EGP"]</span>
                </div>
            </div>
        </div>

        <div class="section-divider"><span>@SharedLocalizer["Medical"]</span></div>
        <div class="section-title"><i class="bi bi-heart-pulse"></i> @SharedLocalizer["Medical Information"]</div>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="form-check mt-2">
                    <input asp-for="HasDisease" class="form-check-input" id="HasDisease" />
                    <label asp-for="HasDisease" class="form-check-label">@SharedLocalizer["Has Disease / Condition"]</label>
                </div>
            </div>
            <div class="col-md-4">
                <label asp-for="DiseaseType" class="form-label">@SharedLocalizer["Disease Type"]</label>
                <input asp-for="DiseaseType" class="form-control" id="DiseaseType" />
                <span asp-validation-for="DiseaseType" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Weight" class="form-label">@SharedLocalizer["Weight (kg)"]</label>
                <div class="input-group">
                    <input asp-for="Weight" class="form-control" type="number" step="0.1" min="0" />
                    <span class="input-group-text">@SharedLocalizer["kg"]</span>
                </div>
            </div>
        </div>

        <div class="section-divider"><span>@SharedLocalizer["Fingerprint"]</span></div>
        <div class="section-title"><i class="bi bi-fingerprint"></i> @SharedLocalizer["Fingerprint"]</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FingerprintDeviceId" class="form-label">@SharedLocalizer["Device ID"]</label>
                <input asp-for="FingerprintDeviceId" class="form-control" type="number" />
            </div>
        </div>

        <div class="section-divider"><span>@SharedLocalizer["Signatures"]</span></div>
        <div class="section-title"><i class="bi bi-pen"></i> @SharedLocalizer["Signatures"]</div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="MemberSignature" class="form-label">@SharedLocalizer["Member Signature"]</label>
                <textarea asp-for="MemberSignature" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-6">
                <label asp-for="AdminSignature" class="form-label">@SharedLocalizer["Admin Signature"]</label>
                <textarea asp-for="AdminSignature" class="form-control" rows="3"></textarea>
            </div>
        </div>

        <div class="receipt-footer px-0 pb-0 mt-3">
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @SharedLocalizer["Create Member"]</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const price = document.getElementById('SubscriptionPrice');
            const paid = document.getElementById('PaidAmount');
            const remaining = document.getElementById('remainingAmount');
            const hasDisease = document.getElementById('HasDisease');
            const diseaseType = document.getElementById('DiseaseType');

            function calcRemaining() {
                const p = parseFloat(price.value) || 0;
                const a = parseFloat(paid.value) || 0;
                remaining.value = Math.max(0, p - a).toFixed(2);
            }

            price.addEventListener('input', calcRemaining);
            paid.addEventListener('input', calcRemaining);
            calcRemaining();

            hasDisease.addEventListener('change', function() {
                diseaseType.disabled = !this.checked;
                if (!this.checked) diseaseType.value = '';
            });

            if (!hasDisease.checked) diseaseType.disabled = true;
        });
    </script>
}
