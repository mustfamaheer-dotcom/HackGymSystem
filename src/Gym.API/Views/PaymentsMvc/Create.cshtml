@model CreatePaymentCommand
@{
    var error = TempData["Error"] as string;
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> New Payment</h4>
                <span class="receipt-badge">Payment</span>
            </div>
            <form asp-action="Create" method="post" class="receipt-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="MemberId" class="form-label">Member</label>
                        <input asp-for="MemberId" class="form-control" placeholder="Enter member ID" />
                        <span asp-validation-for="MemberId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Amount" class="form-label">Amount</label>
                        <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="e.g. 500" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="DiscountAmount" class="form-label">Discount</label>
                        <input asp-for="DiscountAmount" type="number" step="0.01" class="form-control" placeholder="0" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PaymentMethod" class="form-label">Payment Method</label>
                        <select asp-for="PaymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ReceiptNumber" class="form-label">Receipt Number</label>
                        <input asp-for="ReceiptNumber" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ReferenceNumber" class="form-label">Reference</label>
                        <input asp-for="ReferenceNumber" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmployeeId" class="form-label">Employee ID</label>
                        <input asp-for="EmployeeId" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
                    </div>
                </div>
                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
