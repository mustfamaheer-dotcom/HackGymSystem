@model PaginatedResult<PaymentDto>
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-credit-card"></i> Payments</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> New Payment</a>
    </div>
    <div class="p-3 border-bottom bg-light">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-2">
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    <option value="10" selected="@(Model?.PageSize == 10 ? "selected" : null)">10 per page</option>
                    <option value="20" selected="@(Model?.PageSize == 20 ? "selected" : null)">20 per page</option>
                    <option value="50" selected="@(Model?.PageSize == 50 ? "selected" : null)">50 per page</option>
                </select>
            </div>
        </form>
    </div>
    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success m-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger m-3">@TempData["Error"]</div>
    }
    @if (Model is null || Model.Items.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-credit-card" style="font-size: 3rem;"></i>
            <p class="mt-2">No payments found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Receipt</th>
                        <th>Member</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Method</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@payment.ReceiptNumber</td>
                            <td>@payment.MemberName</td>
                            <td>@payment.TotalAmount.ToString("N2") EGP</td>
                            <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                            <td>@payment.PaymentMethod</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@payment.Id" class="btn btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Items.Count of @Model.TotalCount payments</small>
            <nav>
                <ul class="pagination pagination-sm">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Previous</a></li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a></li>
                    }
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
