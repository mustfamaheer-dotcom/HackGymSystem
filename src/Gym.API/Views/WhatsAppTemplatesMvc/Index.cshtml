@model List<WhatsAppTemplateDto>
@{
    var showActive = ViewBag.ShowActive as bool?;
}

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-whatsapp"></i> @SharedLocalizer["WhatsApp Templates"]</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> @SharedLocalizer["New Template"]</a>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success m-3">@TempData["Success"]</div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger m-3">@TempData["Error"]</div>
    }

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-whatsapp" style="font-size: 3rem;"></i>
            <p class="mt-2">@SharedLocalizer["No templates yet."]</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>@SharedLocalizer["Name"]</th>
                        <th>@SharedLocalizer["Message Preview"]</th>
                        <th class="text-center">@SharedLocalizer["Task"]</th>
                        <th class="text-center">@SharedLocalizer["Active"]</th>
                        <th class="text-center">@SharedLocalizer["Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td style="max-width:400px;">
                                <code style="font-size:0.8rem;white-space:pre-wrap;word-break:break-word;color:var(--text-secondary);">@item.MessageBody</code>
                            </td>
                            <td class="text-center">
                                @if (item.TriggerType.HasValue)
                                {
                                    <span class="badge-status badge-frozen">@SharedLocalizer[item.TriggerType.Value.ToString()]</span>
                                }
                                else
                                {
                                    <span class="text-muted small">@SharedLocalizer["None"]</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge-status @(item.IsActive ? "badge-active" : "badge-expired")">
                                    @(item.IsActive ? SharedLocalizer["Yes"] : SharedLocalizer["No"])
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="@SharedLocalizer["Edit"]"><i class="bi bi-pencil"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
