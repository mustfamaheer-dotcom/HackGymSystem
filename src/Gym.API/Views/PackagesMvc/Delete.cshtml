@model PackageDto
@{
    var error = TempData["Error"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="receipt-card text-center">
            <div class="receipt-header" style="background: linear-gradient(135deg, #FEE2E2, #FECACA);">
                <h4 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Delete Package</h4>
                <span class="receipt-badge">Confirm</span>
            </div>

            <div class="receipt-body">
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }

                <div class="mb-4">
                    <i class="bi bi-box-seam text-danger" style="font-size: 4rem;"></i>
                </div>
                <h5 class="fw-bold">@Model.PackageName</h5>
                <p class="text-muted mb-1">@Model.DurationMonths month(s) - @Model.Price.ToString("N2") EGP</p>

                <div class="alert alert-warning mt-4">
                    <i class="bi bi-info-circle"></i>
                    This action cannot be undone. Packages with active subscriptions cannot be deleted.
                </div>

                <table class="table table-borderless table-sm text-start">
                    <tr><td class="detail-label">Duration</td><td class="detail-value">@Model.DurationMonths month(s)</td></tr>
                    <tr><td class="detail-label">Price</td><td class="detail-value">@Model.Price.ToString("N2") EGP</td></tr>
                    <tr><td class="detail-label">Free Period</td><td class="detail-value">@(Model.FreePeriodMonths?.ToString() ?? "-")</td></tr>
                    <tr><td class="detail-label">Max Freeze Days</td><td class="detail-value">@(Model.MaxFreezeDays?.ToString() ?? "-")</td></tr>
                    <tr>
                        <td class="detail-label">Status</td>
                        <td class="detail-value">
                            <span class="badge-status @(Model.IsActive ? "badge-active" : "badge-expired")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                    </tr>
                </table>

                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Cancel</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Confirm Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
