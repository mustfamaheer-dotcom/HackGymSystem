@{
    var error = TempData["Error"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> New Package</h4>
                <span class="receipt-badge">Package</span>
            </div>

            <form asp-action="Create" method="post" class="receipt-body">
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Package Name</label>
                        <input name="packageName" class="form-control" placeholder="Enter package name" required maxlength="200" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Duration (Months)</label>
                        <input name="durationMonths" type="number" class="form-control" placeholder="e.g. 1" required min="1" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Price (EGP)</label>
                        <input name="price" type="number" step="0.01" class="form-control" placeholder="e.g. 500" required min="0.01" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Free Period (Months)</label>
                        <input name="freePeriodMonths" type="number" class="form-control" placeholder="Optional" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Max Freeze Days</label>
                        <input name="maxFreezeDays" type="number" class="form-control" placeholder="Optional" min="0" />
                    </div>
                </div>

                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
