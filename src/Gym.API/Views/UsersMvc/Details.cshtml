@model UserListItemDto

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-shield-lock-fill"></i> User Details</h4>
        <span class="receipt-badge">@@@Model.Username</span>
    </div>

    <div class="receipt-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="section-title"><i class="bi bi-person-badge"></i> Account Info</div>
                <table class="table table-borderless table-sm">
                    <tr><td class="detail-label">Username</td><td class="detail-value">@Model.Username</td></tr>
                    <tr><td class="detail-label">Full Name</td><td class="detail-value">@Model.FullName</td></tr>
                    <tr><td class="detail-label">Email</td><td class="detail-value">@Model.Email</td></tr>
                    <tr><td class="detail-label">Phone</td><td class="detail-value">@(Model.Phone ?? "-")</td></tr>
                    <tr><td class="detail-label">Role</td><td class="detail-value">@Model.RoleName</td></tr>
                    <tr>
                        <td class="detail-label">Status</td>
                        <td class="detail-value">
                            @if (Model.IsActive)
                            {
                                <span class="badge-status badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-status badge-expired">Inactive</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <div class="section-title"><i class="bi bi-clock-history"></i> Activity</div>
                <table class="table table-borderless table-sm">
                    <tr><td class="detail-label">Created At</td><td class="detail-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><td class="detail-label">Last Login</td><td class="detail-value">@(Model.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "Never")</td></tr>
                </table>
            </div>
        </div>
    </div>

    <div class="receipt-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
</div>
