@model UserListItemDto

<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-shield-lock-fill"></i> @SharedLocalizer["User Details"]</h4>
        <span class="receipt-badge">@@@Model.Username</span>
    </div>

    <div class="receipt-body">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="section-title"><i class="bi bi-person-badge"></i> @SharedLocalizer["Account Info"]</div>
                <table class="table table-borderless table-sm">
                    <tr><td class="detail-label">@SharedLocalizer["Username"]</td><td class="detail-value">@Model.Username</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Full Name"]</td><td class="detail-value">@Model.FullName</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Email"]</td><td class="detail-value">@Model.Email</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Phone"]</td><td class="detail-value">@(Model.Phone ?? "-")</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Role"]</td><td class="detail-value">@Model.RoleName</td></tr>
                    <tr>
                        <td class="detail-label">@SharedLocalizer["Status"]</td>
                        <td class="detail-value">
                            @if (Model.IsActive)
                            {
                                <span class="badge-status badge-active">@SharedLocalizer["Active"]</span>
                            }
                            else
                            {
                                <span class="badge-status badge-expired">@SharedLocalizer["Inactive"]</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <div class="section-title"><i class="bi bi-clock-history"></i> @SharedLocalizer["Activity"]</div>
                <table class="table table-borderless table-sm">
                    <tr><td class="detail-label">@SharedLocalizer["Created At"]</td><td class="detail-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><td class="detail-label">@SharedLocalizer["Last Login"]</td><td class="detail-value">@(Model.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? SharedLocalizer["Never"])</td></tr>
                </table>
            </div>
        </div>
    </div>

    <div class="receipt-footer">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil"></i> @SharedLocalizer["Edit"]</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> @SharedLocalizer["Back to List"]</a>
    </div>
</div>
