@using Gym.Shared.Enums
@model PaginatedResult<OfferDto>
@{
    var searchTerm = ViewBag.SearchTerm as string;
}
<div class="receipt-card">
    <div class="receipt-header">
        <h4><i class="bi bi-megaphone"></i> Offers</h4>
        <a asp-action="Create" class="btn btn-gold btn-sm rounded-pill"><i class="bi bi-plus-lg"></i> New Offer</a>
    </div>
    <div class="p-3 border-bottom bg-light">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by title..." value="@searchTerm" />
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="col-md-2">
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    <option value="10" selected="@(Model?.PageSize == 10 ? "selected" : null)">10 per page</option>
                    <option value="20" selected="@(Model?.PageSize == 20 ? "selected" : null)">20 per page</option>
                    <option value="50" selected="@(Model?.PageSize == 50 ? "selected" : null)">50 per page</option>
                </select>
            </div>
        </form>
    </div>
    @if (Model is null || Model.Items.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-megaphone" style="font-size: 3rem;"></i>
            <p class="mt-2">No offers found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Offer Name</th>
                        <th>Package</th>
                        <th>Offer Type</th>
                        <th>Bonus</th>
                        <th>Offer Price</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var offer in Model.Items)
                    {
                        var bonusText = offer.OfferType switch
                        {
                            OfferType.BonusDuration => $"+{(offer.BonusMonths > 0 ? $"{offer.BonusMonths}m " : "")}{(offer.BonusDays > 0 ? $"{offer.BonusDays}d" : "")}",
                            OfferType.ExtraFreeze => $"+{offer.ExtraFreezeDays}d freeze",
                            OfferType.FreeRegistration => "Free",
                            OfferType.Custom => "-",
                            _ => "-"
                        };
                        <tr>
                            <td class="fw-semibold">@offer.OfferTitle</td>
                            <td>@(offer.LinkedPackageName ?? "All Packages")</td>
                            <td><span class="badge bg-info bg-opacity-10 text-info px-2 py-1 rounded-pill" style="font-size:0.75rem;">@offer.OfferType</span></td>
                            <td>@bonusText</td>
                            <td>@(offer.OfferPrice.HasValue ? offer.OfferPrice.Value.ToString("N2") + " EGP" : "-")</td>
                            <td>@offer.StartDate.ToString("dd/MM/yyyy")</td>
                            <td>@offer.EndDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge-status @(offer.IsActive ? "badge-active" : "badge-expired")">@(offer.IsActive ? "Active" : "Inactive")</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@offer.Id" class="btn btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@offer.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@offer.Id" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted">Showing @Model.Items.Count of @Model.TotalCount offers</small>
            <nav>
                <ul class="pagination pagination-sm">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">Previous</a></li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">@i</a></li>
                    }
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-searchTerm="@searchTerm">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
