@using Gym.Shared.Enums
@model OfferDto
<div class="receipt-card border-danger">
    <div class="receipt-header bg-danger text-white">
        <h4><i class="bi bi-exclamation-triangle"></i> @SharedLocalizer["Delete Offer"]</h4>
        <span class="receipt-badge bg-white text-danger">@SharedLocalizer["Confirm"]</span>
    </div>
    <div class="receipt-body">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@SharedLocalizer["Are you sure you want to delete this offer? This action cannot be undone."]
        </div>
        <div class="section-title"><i class="bi bi-info-circle"></i> @SharedLocalizer["Offer Details"]</div>
        <table class="table table-borderless table-sm">
            <tr><td class="detail-label">@SharedLocalizer["Offer Title"]</td><td class="detail-value">@Model.OfferTitle</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Offer Type"]</td><td class="detail-value">@Model.OfferType</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Linked Package"]</td><td class="detail-value">@(Model.LinkedPackageName ?? SharedLocalizer["All Packages"])</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Status"]</td><td class="detail-value"><span class="badge-status @(Model.IsActive ? "badge-active" : "badge-expired")">@(Model.IsActive ? SharedLocalizer["Active"] : SharedLocalizer["Inactive"])</span></td></tr>
            <tr><td class="detail-label">@SharedLocalizer["Start Date"]</td><td class="detail-value">@Model.StartDate.ToString("dd/MM/yyyy")</td></tr>
            <tr><td class="detail-label">@SharedLocalizer["End Date"]</td><td class="detail-value">@Model.EndDate.ToString("dd/MM/yyyy")</td></tr>
        </table>
    </div>
    <div class="receipt-footer">
        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> @SharedLocalizer["Delete Permanently"]</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
        </form>
    </div>
</div>
