@model UpdateOfferDto
@{
    var error = TempData["Error"] as string;
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-pencil-square"></i> @SharedLocalizer["Edit Offer"]</h4>
                <span class="receipt-badge">@Model.OfferTitle</span>
            </div>
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="receipt-body">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="OfferType" value="FixedPrice" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="OfferTitle" class="form-label">@SharedLocalizer["Offer Title"]</label>
                        <input asp-for="OfferTitle" class="form-control" />
                        <span asp-validation-for="OfferTitle" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LinkedPackageId" class="form-label">@SharedLocalizer["Linked Package"]</label>
                        <select asp-for="LinkedPackageId" class="form-select">
                            <option value="">@SharedLocalizer["-- All Packages --"]</option>
                            @foreach (var plan in ViewBag.Plans as List<MembershipPlan> ?? new())
                            {
                                <option value="@plan.Id">@($"{plan.Name} ({plan.Price:N2} {SharedLocalizer["EGP"]})")</option>
                            }
                        </select>
                        <span class="text-muted small">@SharedLocalizer["Optional — leave empty for a standalone offer"]</span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="OfferPrice" class="form-label">@SharedLocalizer["Offer Price (EGP)"]</label>
                        <input asp-for="OfferPrice" type="number" step="0.01" min="0.01" class="form-control" />
                        <span asp-validation-for="OfferPrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BonusMonths" class="form-label">@SharedLocalizer["Duration Months"]</label>
                        <input asp-for="BonusMonths" type="number" min="0" class="form-control" />
                        <span class="text-muted small">@SharedLocalizer["Extra months added to subscription"]</span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BonusDays" class="form-label">@SharedLocalizer["Extra Days"]</label>
                        <input asp-for="BonusDays" type="number" min="0" class="form-control" />
                        <span class="text-muted small">@SharedLocalizer["Extra days added to subscription"]</span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="StartDate" class="form-label">@SharedLocalizer["Start Date"]</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label">@SharedLocalizer["End Date"]</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label">@SharedLocalizer["Description"]</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @SharedLocalizer["Update"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
