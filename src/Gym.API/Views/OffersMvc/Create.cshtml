@using Gym.Shared.Enums
@model CreateOfferDto
@{
    var error = TempData["Error"] as string;
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="receipt-card">
            <div class="receipt-header">
                <h4><i class="bi bi-plus-circle"></i> @SharedLocalizer["New Offer"]</h4>
                <span class="receipt-badge">@SharedLocalizer["Offer"]</span>
            </div>
            <form asp-action="Create" method="post" class="receipt-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (!string.IsNullOrEmpty(error))
                {
                    <div class="alert alert-danger">@error</div>
                }
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="OfferTitle" class="form-label">@SharedLocalizer["Offer Title"]</label>
                        <input asp-for="OfferTitle" class="form-control" placeholder="@SharedLocalizer["e.g. 2+1 Free"]" />
                        <span asp-validation-for="OfferTitle" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LinkedPackageId" class="form-label">@SharedLocalizer["Linked Package"]</label>
                        <select asp-for="LinkedPackageId" class="form-select">
                            <option value="">@SharedLocalizer["-- All Packages --"]</option>
                            @foreach (var plan in ViewBag.Plans as List<MembershipPlan> ?? new())
                            {
                                <option value="@plan.Id">@($"{plan.Name} ({plan.Price:N2} {SharedLocalizer["EGP"]})")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="OfferType" class="form-label">@SharedLocalizer["Offer Type"]</label>
                        <select asp-for="OfferType" class="form-select" id="offerTypeSelect" asp-items="Html.GetEnumSelectList<OfferType>()">
                            <option value="">@SharedLocalizer["-- Select --"]</option>
                        </select>
                        <span asp-validation-for="OfferType" class="text-danger small"></span>
                    </div>

                    <div class="col-12" id="bonusFields" style="display:none;">
                        <div class="section-title mt-2"><i class="bi bi-clock-history"></i> @SharedLocalizer["Bonus Duration"]</div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="BonusMonths" class="form-label">@SharedLocalizer["Bonus Months"]</label>
                                <input asp-for="BonusMonths" type="number" min="1" class="form-control" placeholder="@SharedLocalizer["e.g. 1"]" />
                                <span asp-validation-for="BonusMonths" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="BonusDays" class="form-label">@SharedLocalizer["Bonus Days"]</label>
                                <input asp-for="BonusDays" type="number" min="1" class="form-control" placeholder="@SharedLocalizer["e.g. 15"]" />
                                <span asp-validation-for="BonusDays" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6" id="priceField" style="display:none;">
                        <label asp-for="OfferPrice" class="form-label">@SharedLocalizer["Offer Price (EGP)"]</label>
                        <input asp-for="OfferPrice" type="number" step="0.01" min="0" class="form-control" placeholder="@SharedLocalizer["e.g. 5000"]" />
                        <span asp-validation-for="OfferPrice" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6" id="freezeField" style="display:none;">
                        <label asp-for="ExtraFreezeDays" class="form-label">@SharedLocalizer["Extra Freeze Days"]</label>
                        <input asp-for="ExtraFreezeDays" type="number" min="1" class="form-control" placeholder="@SharedLocalizer["e.g. 30"]" />
                        <span asp-validation-for="ExtraFreezeDays" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label">@SharedLocalizer["Start Date"]</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label">@SharedLocalizer["End Date"]</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label">@SharedLocalizer["Description"]</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="@SharedLocalizer["Optional description"]"></textarea>
                    </div>
                </div>
                <div class="receipt-footer px-0 pb-0 mt-3">
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> @SharedLocalizer["Cancel"]</a>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> @SharedLocalizer["Create"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleOfferFields() {
        var type = document.getElementById('offerTypeSelect').value;
        document.getElementById('bonusFields').style.display = (type === 'BonusDuration') ? 'block' : 'none';
        document.getElementById('priceField').style.display = (type === 'FixedPrice' || type === 'FreeRegistration') ? 'block' : 'none';
        document.getElementById('freezeField').style.display = (type === 'ExtraFreeze') ? 'block' : 'none';
    }
    document.getElementById('offerTypeSelect').addEventListener('change', toggleOfferFields);
    toggleOfferFields();
</script>
